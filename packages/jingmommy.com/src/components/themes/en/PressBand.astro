---
/* "As featured in" press row — Jost caps text only, no colored logos.
   `press` is passed in by the page (single-page config — see CLAUDE.md). */
interface Props {
  press: string[]
}
const { press } = Astro.props
---

<section class="trustband reveal">
  <div class="trust-row">
    <span>As featured in</span>
    {
      press.map((name) => (
        <>
          <span class="trust-dot" />
          <span class="featured">{name}</span>
        </>
      ))
    }
  </div>
</section>
