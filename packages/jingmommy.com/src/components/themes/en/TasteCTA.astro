---
/*
  Default "Taste before you commit" CTA — a preset of the shared CtaBand.
  Kept as a named component so pages can drop in the standard taste CTA with
  no props.
*/
import CtaBand from "./CtaBand.astro"
import { formatNumber, orderUrl, tastingReserveUrl } from '@/utils/index.ts'
import { site, products } from '@/config/index.ts'
import { usd } from '@/utils/index.ts'

interface Props {
  eyebrow?: string
  heading?: string
  body?: string
}
const {
  eyebrow = "Not sure yet?",
  heading = "Taste before you commit.",
  body = `Over ${formatNumber(site.mothersServed)} mothers have trusted JingMommy with their recovery — most tried a taste first. Join a free local tasting, or have a full sample day delivered: ${usd(products.local_classic_sample_1d.price)} fresh in SoCal, ${usd(products.frozen_classic_sample_8item.price)} frozen nationwide.`,
} = Astro.props
---

<CtaBand
  id="taste"
  eyebrow={eyebrow}
  heading={heading}
  body={body}
  buttons={[
    {
      label: "Reserve a free tasting",
      href: tastingReserveUrl('en'),
      variant: "primary",
    },
    {
      label: `Order a sample — ${usd(products.local_classic_sample_1d.price)} local · ${usd(products.frozen_classic_sample_8item.price)} frozen`,
      href: orderUrl('sample_meals', 'en'),
      variant: "ghost",
    },
  ]}
/>
