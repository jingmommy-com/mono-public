---
/*
  Open cross-origin links in a new tab (en site).

  Any <a> that points to a different origin than the current page — e.g. the
  order system at order.jingmommy.com — gets `target="_blank"` + a safe `rel`.

  Exception: locale-switch links (`[data-locale-target]`). Those navigate the
  *same app* across its production domains (jingmommy.com ↔ postpartummeal.com,
  rewritten by LocaleDomainSwitch), so they should stay in the same tab.

  Runs client-side because "cross-origin" depends on the runtime origin (the same
  build serves multiple domains).
*/
---

<script is:inline>
  ;(function () {
    var origin = location.origin
    document.querySelectorAll('a[href]').forEach(function (a) {
      // Same-app cross-domain locale switch → keep in the same tab.
      if (a.hasAttribute('data-locale-target')) return
      var href = a.getAttribute('href') || ''
      if (!/^https?:\/\//i.test(href)) return // relative/same-origin links: leave as-is
      try {
        if (new URL(href, origin).origin !== origin) {
          a.target = '_blank'
          a.rel = 'noopener noreferrer'
        }
      } catch (e) {}
    })
  })()
</script>
