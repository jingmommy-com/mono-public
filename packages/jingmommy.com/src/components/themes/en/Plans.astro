---
/*
  The five meal-plan cards. Shared between the landing page and Meal Plans page.
  Cards come from config `plans`; each has a botanical corner sprig.
*/
import { products } from '@/config/index.ts'
import { route, usd } from '@/utils/index.ts'

/** The five 30-day meal plans. Names + prices are locked business facts. */
const plans = [
  {
    name: 'Herbal',
    price: usd(products.local_herbal_30d.price),
    per: '30 days',
    featured: true,
    badge: 'Most complete',
    desc: 'The full, uncompromising experience — three meals plus a daily herbal drink. The closest thing to a grandmother cooking for you.',
    persona: 'For the mom who wants to do this completely.',
  },
  {
    name: 'Classic',
    price: usd(products.local_classic_30d.price),
    per: '30 days',
    desc: 'Complete daily support without the guesswork. Three warm, comforting meals a day — meals that feel like Mom’s.',
    persona: 'For the mom who wants daily care, simply.',
  },
  {
    name: 'Vita',
    price: usd(products.local_vita_30d.price),
    per: '30 days',
    desc: 'A lighter, minimalist take — two nourishing meals a day plus a dessert. Perfect for smaller appetites or warmer seasons.',
    persona: 'For the mom who prefers lighter portions.',
  },
  {
    name: 'Low Carb',
    price: usd(products.local_lowcarb_30d.price),
    per: '30 days',
    desc: 'The same warm healing, without rice, grains, or sweet drinks. For the mom caring for her body on her own terms.',
    persona: 'For the mom managing blood sugar or going grain-free.',
  },
  {
    name: 'Easy',
    price: usd(products.local_easy_15d.price),
    per: '30 days · 15 deliveries',
    desc: 'Nourishment with breathing room — warm meals every other day. Ideal if you have help at home and want to supplement.',
    persona: 'For the mom who has family helping and wants to fill the gaps.',
  },
]

interface Props {
  /** Show the "See full plan details" button below the grid. */
  cta?: boolean
  ctaLabel?: string
  ctaHref?: string
}
const {
  cta = false,
  ctaLabel = "See full plan details",
  ctaHref = route("/plans", 'en'),
} = Astro.props
---

<div class="plans">
  {
    plans.map((plan) => (
      <div class:list={["plan", "reveal", { feat: plan.featured }]}>
        <svg
          class="plan-botan"
          viewBox="0 0 64 64"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M52 52 C40 44 28 40 10 38"
            stroke="#B47B5C"
            stroke-width="1.5"
            fill="none"
          />
          <ellipse
            cx="44"
            cy="30"
            rx="8"
            ry="12"
            fill="#C77D7D"
            opacity="0.6"
            transform="rotate(-30 44 30)"
          />
          <ellipse
            cx="36"
            cy="40"
            rx="6"
            ry="10"
            fill="#D99FB0"
            opacity="0.5"
            transform="rotate(-50 36 40)"
          />
          <circle cx="44" cy="30" r="3" fill="#E8C46A" opacity="0.7" />
          <path
            d="M30 48 C22 44 18 36 20 28"
            stroke="#5E6B4F"
            stroke-width="1.2"
            fill="none"
          />
          <ellipse
            cx="22"
            cy="36"
            rx="5"
            ry="8"
            fill="#5E6B4F"
            opacity="0.3"
            transform="rotate(20 22 36)"
          />
        </svg>
        <p class="plan-badge">{plan.badge ?? ""}</p>
        <h3>{plan.name}</h3>
        <p class="plan-price">{plan.price}</p>
        <p class="plan-per">{plan.per}</p>
        <p class="plan-desc">{plan.desc}</p>
        <p class="plan-persona">{plan.persona}</p>
      </div>
    ))
  }
</div>
{
  cta && (
    <div class="center reveal" style="margin-top:48px">
      <a href={ctaHref} class="btn btn-primary">
        {ctaLabel}
      </a>
    </div>
  )
}
