---
/*
  Floating language switch for en pages — a drop-up menu listing the Chinese
  locales. Fixed to the bottom-left, icon-only trigger (Tabler `language` icon);
  the menu opens upward. Styled in the en theme (uses theme.css CSS variables,
  available because Base.astro imports the en theme.css globally).

  The en (new design) and zh sites aren't fully 1:1, but some routes (e.g. the
  postpartum-meals product pages) share the same path across locales. Mirrors
  the base theme's Header.astro switchUrl(): if the same path exists in the
  target locale's route-map, jump straight there; otherwise fall back to that
  locale's home instead of a 404. Locales come from config/index.ts and
  labels/hreflang from i18n/locales.ts — every locale except the current one
  is listed.
*/
import LocaleDomainSwitch from '@/components/LocaleDomainSwitch.astro'
import { locales, localeMeta } from '@/config/index.ts'
import routeMap from '@/route-map.json'

const pathSegments = Astro.url.pathname.split('/').filter(Boolean)
const currentLocale = locales.includes(pathSegments[0]) ? pathSegments[0] : locales[0]
const restSegments = locales.includes(pathSegments[0]) ? pathSegments.slice(1) : pathSegments

function switchUrl(targetLocale: string): string {
  const target = restSegments.length ? `/${targetLocale}/${restSegments.join('/')}` : `/${targetLocale}`
  return Object.hasOwn(routeMap, target) ? target : `/${targetLocale}/`
}

const languages = locales
  .filter(locale => locale !== currentLocale)
  .map(locale => ({ locale, href: switchUrl(locale), ...localeMeta[locale] }))
---

<details class="lang-switch" id="lang-switch">
  <summary aria-label="Switch language · 切換語言" title="Language">
    <!-- Tabler icon: language -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M9 6.371c0 4.418 -2.239 6.629 -5 6.629"></path>
      <path d="M4 6.371h7"></path>
      <path d="M5 9c0 2.144 2.252 3.908 6 4"></path>
      <path d="M12 20l4 -9l4 9"></path>
      <path d="M19.1 18h-6.2"></path>
      <path d="M6.694 3l.793 .582"></path>
    </svg>
  </summary>
  <div class="lang-menu">
    {
      languages.map(lang => (
        <a href={lang.href} data-locale-target={lang.locale} hreflang={lang.hreflang}>
          {lang.label}
        </a>
      ))
    }
  </div>
</details>

<script>
  const el = document.getElementById('lang-switch') as HTMLDetailsElement | null

  // Close the drop-up when clicking outside it
  document.addEventListener('click', (e) => {
    if (el?.open && !el.contains(e.target as Node)) el.open = false
  })

  // Near the bottom of the page, lift the switch so it clears the footer.
  if (el) {
    let ticking = false
    const update = () => {
      ticking = false
      const remaining =
        document.documentElement.scrollHeight - (window.scrollY + window.innerHeight)
      el.classList.toggle('raised', remaining < 110)
    }
    const onScroll = () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(update)
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll, { passive: true })
    update()
  }
</script>

<LocaleDomainSwitch />

<style>
  .lang-switch {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 60;
    transition: transform 0.25s ease;
  }
  /* Near the bottom of the page, lift it so it doesn't cover the footer — but
     only up to 1230px wide; on wider screens the footer doesn't reach it. */
  @media (max-width: 1230px) {
    .lang-switch.raised {
      transform: translateY(-70px);
    }
  }
  .lang-switch summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    background: rgba(250, 246, 241, 0.95);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid var(--accent-deep);
    border-radius: 2px;
    color: var(--accent-deep);
    cursor: pointer;
    list-style: none;
    box-shadow: 0 6px 20px rgba(43, 24, 16, 0.12);
    transition: all 0.2s ease;
  }
  .lang-switch summary::-webkit-details-marker {
    display: none;
  }
  .lang-switch summary:hover,
  .lang-switch[open] summary {
    background: var(--accent-deep);
    color: var(--paper);
  }
  .lang-switch summary:hover {
    transform: translateY(-1px);
  }
  .lang-switch summary:focus-visible {
    outline: 2px solid var(--accent-deep);
    outline-offset: 3px;
  }
  .lang-switch summary svg {
    display: block;
    width: 22px;
    height: 22px;
  }
  /* drop-up menu, opens above the trigger */
  .lang-menu {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    min-width: 128px;
    background: rgba(250, 246, 241, 0.97);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid var(--accent-deep);
    border-radius: 2px;
    box-shadow: 0 6px 20px rgba(43, 24, 16, 0.12);
    overflow: hidden;
  }
  .lang-menu a {
    display: block;
    padding: 10px 14px;
    color: var(--accent-deep);
    text-decoration: none;
    font-size: 15px;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .lang-menu a + a {
    border-top: 1px solid rgba(43, 24, 16, 0.12);
  }
  .lang-menu a:hover,
  .lang-menu a:focus-visible {
    background: var(--accent-deep);
    color: var(--paper);
    outline: none;
  }
  @media (max-width: 560px) {
    .lang-switch {
      right: 16px;
      bottom: 16px;
    }
    .lang-switch summary {
      width: 42px;
      height: 42px;
    }
    .lang-switch summary svg {
      width: 20px;
      height: 20px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lang-switch summary,
    .lang-menu a {
      transition: none;
    }
    .lang-switch summary:hover {
      transform: none;
    }
  }
</style>
