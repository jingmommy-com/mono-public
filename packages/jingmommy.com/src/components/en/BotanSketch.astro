---
/*
  Lighter line-sketch botanical rose — the interior-page botanical style
  (thin terracotta outline + soft rose/sage fills). Decorative only.
  `variant` picks the mirrored TL or BR drawing; `class` positions it.
*/
interface Props {
  variant: "tl" | "br"
  class?: string
  /** stroke/fill group opacity; interior sections use 0.35–0.55. */
  opacity?: number
}
const { variant, class: className = "", opacity = 0.55 } = Astro.props
---

{
  variant === "tl" && (
    <svg
      class:list={["botan", className]}
      viewBox="0 0 200 200"
      aria-hidden="true"
    >
      <g fill="none" stroke="#B47B5C" stroke-width="1.2" opacity={opacity}>
        <path d="M30 40 Q60 60 80 100 T130 170" />
        <path d="M40 60 Q70 80 95 105" />
        <ellipse
          cx="65"
          cy="55"
          rx="8"
          ry="14"
          fill="#C77D7D"
          opacity="0.5"
          stroke="none"
          transform="rotate(-25 65 55)"
        />
        <ellipse
          cx="85"
          cy="78"
          rx="9"
          ry="16"
          fill="#A85A5A"
          opacity="0.4"
          stroke="none"
          transform="rotate(15 85 78)"
        />
        <ellipse
          cx="105"
          cy="115"
          rx="7"
          ry="13"
          fill="#C77D7D"
          opacity="0.45"
          stroke="none"
          transform="rotate(40 105 115)"
        />
        <ellipse
          cx="50"
          cy="90"
          rx="14"
          ry="6"
          fill="#5E6B4F"
          opacity="0.4"
          stroke="none"
          transform="rotate(-50 50 90)"
        />
        <ellipse
          cx="78"
          cy="130"
          rx="16"
          ry="7"
          fill="#5E6B4F"
          opacity="0.45"
          stroke="none"
          transform="rotate(20 78 130)"
        />
        <ellipse
          cx="115"
          cy="155"
          rx="12"
          ry="5"
          fill="#5E6B4F"
          opacity="0.4"
          stroke="none"
          transform="rotate(45 115 155)"
        />
      </g>
    </svg>
  )
}
{
  variant === "br" && (
    <svg
      class:list={["botan", className]}
      viewBox="0 0 200 200"
      aria-hidden="true"
    >
      <g fill="none" stroke="#B47B5C" stroke-width="1.2" opacity={opacity}>
        <path d="M180 30 Q140 60 110 90 T50 160" />
        <path d="M165 50 Q130 75 105 100" />
        <ellipse
          cx="140"
          cy="55"
          rx="9"
          ry="15"
          fill="#C77D7D"
          opacity="0.5"
          stroke="none"
          transform="rotate(35 140 55)"
        />
        <ellipse
          cx="120"
          cy="80"
          rx="8"
          ry="14"
          fill="#A85A5A"
          opacity="0.4"
          stroke="none"
          transform="rotate(-20 120 80)"
        />
        <ellipse
          cx="95"
          cy="110"
          rx="7"
          ry="13"
          fill="#C77D7D"
          opacity="0.45"
          stroke="none"
          transform="rotate(50 95 110)"
        />
        <ellipse
          cx="155"
          cy="90"
          rx="14"
          ry="6"
          fill="#5E6B4F"
          opacity="0.45"
          stroke="none"
          transform="rotate(60 155 90)"
        />
        <ellipse
          cx="120"
          cy="130"
          rx="16"
          ry="7"
          fill="#5E6B4F"
          opacity="0.4"
          stroke="none"
          transform="rotate(-20 120 130)"
        />
        <ellipse
          cx="80"
          cy="155"
          rx="12"
          ry="5"
          fill="#5E6B4F"
          opacity="0.4"
          stroke="none"
          transform="rotate(-45 80 155)"
        />
      </g>
    </svg>
  )
}
