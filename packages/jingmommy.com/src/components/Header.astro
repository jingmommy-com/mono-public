---
import { Icon } from 'astro-icon/components'

const {
  fixed = true, // default is fixed
  color = 'orange',
} = Astro.props

const activeDesktop = `border-${color}-500 text-${color}-500`
const activeMobile = `text-${color}-500 bg-${color}-50`

const currentPath = Astro.url.pathname

const navTabs = [
  { href: "/zh-tw/about", label: "金品故事" },
  { href: "/zh-tw/postpartum-meals", label: "月子膳食" },
  { href: "/zh-tw/postpartum-meals/frozen-postpartum-meals", label: "冷凍月子餐" },
  { href: "/zh-tw/miscarriage-healing-meals", label: "小產調養餐" },
  { href: "/zh-tw/post-surgery-meals", label: "手術後餐" },
  { href: "/zh-tw/postpartum-meals/healthy-meals", label: "健康餐" },
  { href: "/zh-tw/postpartum-products/herbal-drink-pack", label: "月子藥膳包" },
  { href: "/zh-tw/sample/tasting-party", label: "預約試吃" },
  { href: "/delivery-lookup", label: "送餐範圍查詢" },
]

const matchesTab = (href: string) =>
  currentPath === href || currentPath === href + '/' || currentPath.startsWith(href + '/')

const activeHref = navTabs
  .filter(tab => matchesTab(tab.href))
  .sort((a, b) => b.href.length - a.href.length)[0]?.href

const isActive = (href: string) => href === activeHref

// Compose class string for header
const headerBaseClasses = [
  'bg-neutral-700',
  'w-full',
  'flex',
  'items-center',
  'justify-between',
  'px-2',
]
const headerFixedClasses = [
  'fixed',
  'top-0',
  'left-0',
  'z-50'
]
if (fixed) {
  headerBaseClasses.unshift(...headerFixedClasses)
}
const headerClass = headerBaseClasses.join(' ')
const headerHeight = [
  'h-16',
  'sm:h-20',
  'lg:h-24'
].join(' ')
---

{fixed && (
  <div class={`w-full ${headerHeight} pointer-events-none invisible`}></div>
)}
<header class={headerClass}>
  <div class="flex items-center justify-start shrink-0">
    <a href="/" class={`flex items-center py-2 ${headerHeight}`}>
      <img src="//file.jingmommy.com/img/logo-white-448x140.png" alt="Jing Mommy Logo" class="h-14" />
    </a>
  </div>

  <!-- Desktop Nav Tabs -->
  <nav class="hidden lg:flex items-end self-end gap-1 overflow-x-auto scrollbar-none pb-0">
    {navTabs.map(tab => (
      <a
        href={tab.href}
        class:list={[
          'px-3 py-2 text-sm font-medium whitespace-nowrap transition-colors border-b-2',
          isActive(tab.href)
            ? activeDesktop
            : 'border-transparent text-gray-300 hover:text-white hover:border-gray-400'
        ]}
      >
        {tab.label}
      </a>
    ))}
  </nav>

  <!-- Mobile Nav -->
  <div class="relative lg:hidden flex items-center">
    <button
      id="mobile-nav-menu-btn"
      type="button"
      class="flex items-center justify-center w-10 h-10 rounded text-2xl"
      aria-label="Open menu"
    >
      <Icon name="mdi:format-list-bulleted" size="1.5em" class="text-gray-100" />
    </button>
    <div
      id="mobile-nav-menu"
      style="display: none;"
      class="absolute right-0 top-12 z-50 w-48 bg-white rounded shadow-lg py-2 text-gray-900"
    >
      {navTabs.map(tab => (
        <a
          href={tab.href}
          class:list={[
            'block px-4 py-2.5 text-sm font-medium transition-colors',
            isActive(tab.href)
              ? activeMobile
              : 'text-gray-800 hover:bg-gray-100'
          ]}
        >
          {tab.label}
        </a>
      ))}
    </div>
    <script type="text/javascript" is:inline>
      (function() {
        let navMenuOpen = false
        function toggleNavMenu() {
          navMenuOpen = !navMenuOpen
          const el = document.getElementById('mobile-nav-menu')
          if (el) {
            el.style.display = navMenuOpen ? 'block' : 'none'
          }
        }
        function closeNavMenu() {
          navMenuOpen = false
          const el = document.getElementById('mobile-nav-menu')
          if (el) {
            el.style.display = 'none'
          }
        }
        const btn = document.getElementById('mobile-nav-menu-btn')
        if (btn) btn.addEventListener('click', function(e) {
          e.stopPropagation()
          toggleNavMenu()
        })
        document.addEventListener('click', function(event) {
          const menu = document.getElementById('mobile-nav-menu')
          const button = document.getElementById('mobile-nav-menu-btn')
          if (menu && menu.style.display === 'block' && !menu.contains(event.target) && !button.contains(event.target)) {
            closeNavMenu()
          }
        })
        const menu = document.getElementById('mobile-nav-menu')
        if (menu) {
          menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeNavMenu)
          })
        }
      })()
    </script>
  </div>
</header>
