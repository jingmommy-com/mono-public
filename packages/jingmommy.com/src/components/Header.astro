---
import { Icon } from 'astro-icon/components'
import { locales } from '@/client.config.ts'
import routeMap from '@/route-map.json'

const {
  fixed = true, // default is fixed
  color = 'orange',
} = Astro.props

const activeDesktop = `border-${color}-500 text-${color}-500`
const activeMobile = `text-${color}-500 bg-${color}-50`

const currentPath = Astro.url.pathname

// Language switcher
const pathSegments = currentPath.split('/').filter(Boolean)
const currentLocale = locales.includes(pathSegments[0]) ? pathSegments[0] : locales[0]

const localeLabels: Record<string, string> = {
  'zh-tw': '繁中',
  'en': 'EN',
}

function switchUrl(targetLocale: string): string {
  if (locales.includes(pathSegments[0])) {
    const rest = pathSegments.slice(1)
    return rest.length ? `/${targetLocale}/${rest.join('/')}` : `/${targetLocale}`
  }
  return currentPath // non-localized path, keep as-is
}

const otherLocales = locales.filter(l => l !== currentLocale)

const navTabs = [
  { href: `/${currentLocale}/about` },
  { href: `/${currentLocale}/postpartum-meals` },
  { href: `/${currentLocale}/postpartum-meals/frozen-postpartum-meals` },
  { href: `/${currentLocale}/miscarriage-healing-meals` },
  { href: `/${currentLocale}/post-surgery-meals` },
  { href: `/${currentLocale}/postpartum-meals/healthy-meals` },
  { href: `/${currentLocale}/postpartum-products/herbal-drink-pack` },
  { href: `/${currentLocale}/sample/` },
  { href: `/${currentLocale}/delivery-lookup` },
].map(row => {
  if (Object.hasOwn(row, 'label')) {
    return row as { href: string; label: string }
  }
  const { href } = row
  const cleanHref = href.replace(/\/$/, '')
  let label = ''
  if (Object.hasOwn(routeMap, cleanHref)) {
    // @ts-ignore
    const meta = routeMap[cleanHref]
    label = meta.shortName?.trim() || meta.title?.trim() || ''
  }
  if (!label) {
    label = cleanHref.replace(/\/$/, '').split('/').filter(Boolean).pop() || ''
    label = label
      .replace(/-/g, ' ')
      .replace(/\b\w/g, c => c.toUpperCase())
      .trim()
  }
  return { ...row, label }
})

const matchesTab = (href: string) =>
  currentPath === href || currentPath === href + '/' || currentPath.startsWith(href + '/')

const activeHref = navTabs
  .filter(tab => matchesTab(tab.href))
  .sort((a, b) => b.href.length - a.href.length)[0]?.href

const isActive = (href: string) => href === activeHref

// Compose class string for header
const baseClasses = [
  'bg-neutral-700',
  'w-full',
  'flex',
  'items-center',
  'justify-between',
  'px-2',
]
const fixedClasses = [
  'fixed',
  'top-0',
  'left-0',
  'z-50'
]
if (fixed) {
  baseClasses.unshift(...fixedClasses)
}
const baseClass = baseClasses.join(' ')
const heightClasses = [
  'h-16',
  'sm:h-18',
  'lg:h-20'
]
const heightClass = heightClasses.join(' ')
---

{fixed && (
  <div class={`w-full ${heightClass} pointer-events-none invisible`}></div>
)}
<header class={baseClass}>
  <div class="flex items-center justify-start shrink-0">
    <a href="/" class={`flex items-center py-2 ${heightClass}`}>
      <img src="//file.jingmommy.com/img/logo-white-448x140.png" alt="Jing Mommy Logo" class="h-14" />
    </a>

    <!-- Language Switcher -->
    <div class="relative shrink-0 flex items-center px-1">
      <details id="lang-switcher" class="group/lang">
        <summary class="flex items-center gap-1 px-2 py-1.5 rounded cursor-pointer select-none list-none text-sm font-semibold text-gray-300 hover:text-white hover:bg-white/10 transition-colors">
          <Icon name="mdi:translate" size="1.1em" />
          <span>{localeLabels[currentLocale]}</span>
          <Icon name="mdi:chevron-down" size="1em" class="transition-transform group-open/lang:rotate-180" />
        </summary>
        <div class="absolute right-0 top-full mt-1 z-50 bg-white rounded shadow-lg py-1 min-w-[80px]">
          {otherLocales.map(locale => (
            <a
              href={switchUrl(locale)}
              class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors whitespace-nowrap"
            >
              {localeLabels[locale]}
            </a>
          ))}
        </div>
      </details>
    </div>
  </div>

  <!-- Desktop Nav Tabs -->
  <nav class="hidden lg:flex lg:flex-wrap items-end self-end gap-1 justify-end pb-0">
    {navTabs.map(tab => (
      <a
        href={tab.href}
        class:list={[
          'px-3 py-2 text-sm font-medium whitespace-nowrap transition-colors border-b-2',
          isActive(tab.href)
            ? activeDesktop
            : 'border-transparent text-gray-300 hover:text-white hover:border-gray-400'
        ]}
      >
        {tab.label}
      </a>
    ))}
  </nav>

  <!-- Mobile Nav -->
  <div class="relative lg:hidden flex items-center">
    <button
      id="mobile-nav-menu-btn"
      type="button"
      class="flex items-center justify-center w-10 h-10 rounded text-2xl"
      aria-label="Open menu"
    >
      <Icon name="mdi:format-list-bulleted" size="1.5em" class="text-gray-100" />
    </button>
    <div
      id="mobile-nav-menu"
      style="display: none;"
      class="absolute right-0 top-12 z-50 w-48 bg-white rounded shadow-lg py-2 text-gray-900"
    >
      {navTabs.map(tab => (
        <a
          href={tab.href}
          class:list={[
            'block px-4 py-2.5 text-sm font-medium transition-colors',
            isActive(tab.href)
              ? activeMobile
              : 'text-gray-800 hover:bg-gray-100'
          ]}
        >
          {tab.label}
        </a>
      ))}
    </div>
    <script type="text/javascript" is:inline>
      (function() {
        let navMenuOpen = false
        function toggleNavMenu() {
          navMenuOpen = !navMenuOpen
          const el = document.getElementById('mobile-nav-menu')
          if (el) {
            el.style.display = navMenuOpen ? 'block' : 'none'
          }
        }
        function closeNavMenu() {
          navMenuOpen = false
          const el = document.getElementById('mobile-nav-menu')
          if (el) {
            el.style.display = 'none'
          }
        }
        const btn = document.getElementById('mobile-nav-menu-btn')
        if (btn) btn.addEventListener('click', function(e) {
          e.stopPropagation()
          toggleNavMenu()
        })
        document.addEventListener('click', function(event) {
          const menu = document.getElementById('mobile-nav-menu')
          const button = document.getElementById('mobile-nav-menu-btn')
          if (menu && menu.style.display === 'block' && !menu.contains(event.target) && !button.contains(event.target)) {
            closeNavMenu()
          }
        })
        const menu = document.getElementById('mobile-nav-menu')
        if (menu) {
          menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeNavMenu)
          })
        }
      })()
    </script>
  </div>
</header>

<script>
  // Close lang switcher when clicking outside
  document.addEventListener('click', (e) => {
    const el = document.getElementById('lang-switcher') as HTMLDetailsElement | null
    if (el?.open && !el.contains(e.target as Node)) el.open = false
  })
</script>
