---
import Layout from '@/layouts/MarkdownPage.astro'
import { Alert, AlertDescription } from '@/components/starwind/alert'

const title = '配送地區查詢 / Delivery Lookup'
const color = 'orange'
const description = '查詢您的郵遞區號是否可配送月子餐及配送方式 / Check if your zipcode is eligible for postpartum meal delivery and available shipping methods.'

const messages = {
  loading: {
    class: 'text-gray-400',
    lines: ['查詢中 / Loading...']
  },
  systemError: {
    class: 'text-rose-600',
    lines: [
      '發生錯誤，請稍後再試。',
      'Something went wrong. Please try again later.'
    ]
  },
  zipError: {
    class: 'text-rose-600',
    lines: [
      '請輸入正確的五碼郵遞區號',
      'Please enter a valid 5-digit zipcode'
    ]
  },
  default: {
    class: 'text-gray-700',
    lines: [
      '請輸入五碼的郵遞區號',
      'Please enter a zipcode'
    ]
  },
  everyDay: {
    lines: [
      '每天免費新鮮配送，每天配送。',
      'Free Delivery Everyday.'
    ]
  },
  everyOtherDayFree: {
    lines: [
      '每2天免費新鮮配送。',
      'Free Delivery Every Other Day'
    ]
  },
  everyOtherDay: {
    lines: [
      '每月附加 $200 美元運費，每隔一天送兩天的餐點。',
      "With a $200 monthly shipping surcharge, meals are delivered every other day, two days' worth at a time."
    ]
  },
  frozen: {
    lines: ['冷凍運送 / Frozen Meal Delivery.']
  },
  contact: {
    lines: [
      '<a href="//order.jingmommy.com/customer-service" target="_blank">聯繫我們</a>決定運送選項',
      '<a href="//order.jingmommy.com/customer-service" target="_blank">Contact Us</a> for Delivery Options'
    ]
  },
  eastvale: {
    lines: [
      '每天配送。Free Delivery Everyday.',
      '(Eastvale only)',
      '其他地區請<a href="//order.jingmommy.com/customer-service" target="_blank">聯繫我們</a>決定運送選項',
      'For other regions, please <a href="//order.jingmommy.com/customer-service" target="_blank">contact us</a> to determine available delivery options.'
    ]
  }
}
---

<Layout title={title} description={description}>
  <Alert variant="warning" class="mx-auto text-center max-w-160">
    <AlertDescription>
      請輸入您的郵遞區號查詢是否可配送月子餐及相關配送方式。<br />
      Enter your zipcode below to check if your address is available for postpartum meal delivery and the available delivery methods.
    </AlertDescription>
  </Alert>
  <div class="flex justify-center pt-4">
    <div class="w-full max-w-md flex flex-col gap-4">
      <div
        id="zipResult"
        class="p-4 rounded-lg bg-blue-50 text-md font-bold hidden"
      >
        <div class="text-gray-800"></div>
      </div>
      <label for="zipCode" class="text-md font-medium text-gray-800">
        郵遞區號 / Zip Code
      </label>
      <input
        id="zipCode"
        name="zipCode"
        type="text"
        pattern="\d{5}"
        class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="e.q. 91789"
        autocomplete="postal-code"
        maxlength="5"
      />
      <button
        id="checkZipBtn"
        type="button"
        class="cursor-pointer w-full bg-blue-700 border border-blue-800 hover:bg-blue-900 text-white font-semibold py-2 px-4 rounded transition-colors"
      >
        查詢 / Lookup
      </button>
    </div>
  </div>
  <script is:inline define:vars={{messages}}>
    function formatZip(str) {
      return str.trim().replace(/[\uFF10-\uFF19]/g, function(ch) {
        return String.fromCharCode(ch.charCodeAt(0) - 0xFF10 + 0x30)
      })
    }
    const zipInput = document.getElementById('zipCode')
    const resultDiv = document.getElementById('zipResult')
    const resultContentDiv = document.querySelector('#zipResult > div')
    const lookupBtn = document.getElementById('checkZipBtn')
    function renderMsg(msgObj) {
      let html = ''
      if (Array.isArray(msgObj.lines)) {
        html = msgObj.lines.map(line => `<div>${line}</div>`).join('')
      } else {
        html = `<span>${msgObj.lines}</span>`
      }
      resultContentDiv.innerHTML = html
      resultContentDiv.className = msgObj.class || messages.default.class
      if (msgObj === messages.default) {
        resultDiv.classList.add('hidden')
      } else {
        resultDiv.classList.remove('hidden')
        resultDiv.focus({preventScroll: false})
        resultDiv.scrollIntoView({behavior: 'smooth', block: 'center'})
      }
    }
    function showLoading() {
      renderMsg(messages.loading)
    }
    function handleLookup() {
      let zip = formatZip(zipInput.value)
      if (!/^\d{5}$/.test(zip)) {
        renderMsg(messages.zipError)
        return
      }
      if (zip === '92880') {
        renderMsg(messages.eastvale)
        return
      }
      showLoading()
      fetch('https://order.jingmommy.com/-/api/delivery_zip', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ zip_code: zip })
      })
      .then(response => {
        if (!response.ok) throw new Error('Network error')
        return response.json()
      })
      .then(data => {
        let code = null
        if (Array.isArray(data.data)) {
          const row = data.data.find(r => r.zip_code === zip)
          if (row && typeof row.delivery_code !== 'undefined') {
            code = row.delivery_code
          }
        }
        let msgObj
        switch (code) {
          case 1:
            msgObj = messages.everyDay
            break
          case 2:
            msgObj = messages.everyOtherDay
            break
          case 3:
            msgObj = messages.frozen
            break
          case 0:
          case 4:
          default:
            msgObj = messages.contact
        }
        renderMsg(msgObj)
      })
      .catch(e => {
        renderMsg(messages.systemError)
        console.error(e)
      })
    }

    if (zipInput && resultDiv && lookupBtn) {
      zipInput.addEventListener('input', function(e) {
        zipInput.value = formatZip(zipInput.value)
      })
      zipInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          handleLookup()
        }
      })
      lookupBtn.addEventListener('click', function() {
        handleLookup()
      })
      renderMsg(messages.default)
    }
  </script>
</Layout>