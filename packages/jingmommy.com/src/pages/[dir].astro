---
import routeMap from '../route-map.json'

export function getStaticPaths() {
  const dirs = Object.keys(routeMap)
    .reduce((acc, key) => {
      const segments = key.split('/').filter(Boolean)
      if (segments.length === 2) {
        acc.push(segments[1])
      }
      return acc
    }, [] as string[])
  return [...new Set(dirs)].map(dir => ({ params: { dir } }))
}
---

<script>
  if (typeof window !== 'undefined') {
    const dir = window.location.pathname.split('/').filter(Boolean)[0]
    if (dir) {
      let locale = 'zh-tw'
      if (navigator.language) {
        locale = navigator.language.toLowerCase()
        if (!['zh-tw', 'en'].includes(locale)) {
          locale = 'zh-tw'
        }
      }
      window.location.replace(`/${locale}/${dir}`)
    }
  }
</script>