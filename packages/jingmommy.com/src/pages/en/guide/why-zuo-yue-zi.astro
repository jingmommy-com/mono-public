---
import Base from "@/layouts/themes/en/Base.astro"
import TopBar from "@/components/themes/en/TopBar.astro"
import Footer from "@/components/themes/en/Footer.astro"
import Botanical from "@/components/themes/en/Botanical.astro"
import CtaBand from "@/components/themes/en/CtaBand.astro"
import { route } from "@/config/en.ts"
import { products, usd } from '@/client.config.ts'

const title = "What Is Zuo Yue Zi? The Chinese Postpartum Tradition — JingMommy"
const description =
  "Zuo Yue Zi is the 2,000-year-old Chinese practice of structured postpartum recovery through warmth, rest, and staged nourishment. Learn the three-stage framework, four principles, and what to eat."

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "What Is Zuo Yue Zi? The Chinese Postpartum Tradition",
    author: {
      "@type": "Person",
      name: "Nicole Huang",
      jobTitle: "Founder, JingMommy",
    },
    publisher: { "@type": "Organization", name: "JingMommy" },
    about: "Zuo Yue Zi — Chinese postpartum confinement and recovery",
  },
]
const p7 = (hash: string) => `${route("/guide/chinese-food-therapy")}#${hash}`
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <TopBar active={route("/guide/why-zuo-yue-zi")} />

  <!-- HERO -->
  <section class="hero p3-hero">
    <Botanical variant="hero-tl" />
    <Botanical variant="hero-br" />
    <div class="hero-inner">
      <p class="eyebrow reveal">Why Zuo Yue Zi</p>
      <h1 class="reveal">
        If you grew up hearing about <em>Zuo Yue Zi,</em><br />or have no idea
        how to start —<br />this page is for you.
      </h1>
      <p class="definition reveal">
        Zuo Yue Zi (坐月子) — literally “sitting the month” — is the Chinese
        practice of structured postpartum recovery through warmth, rest, and
        staged nourishment. Practiced for over 2,000 years, it is one of the
        most complete postpartum care systems in the world.
      </p>
      <p class="lede reveal">
        It is not a fad, not a restrictive ritual, and not reserved for Chinese
        families. What you eat in the first 30 days after birth affects your
        hormones, your milk supply, your energy, and your long-term recovery —
        for months to come.
      </p>
      <a href={route("/sample")} class="hero-gift reveal"
        >Buying this as a gift for someone? Start here →</a
      >
    </div>
  </section>

  <!-- REAL OUTCOMES -->
  <section class="band band-paper">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">What mothers experience</p>
        <h2>Real outcomes from<br />10,000+ families.</h2>
        <p>
          Mothers who follow the Zuo Yue Zi framework consistently report the
          same results — stronger milk supply, faster return of energy, reduced
          joint pain. These are not promises. They are what happens when the
          body gets what it actually needs.
        </p>
      </div>
      <div class="outcomes">
        <div class="outcome reveal">
          <div class="outcome-mark">i.</div>
          <h3>Stronger milk supply</h3>
          <p>Iron- and collagen-rich foods support lactation from Week 1.</p>
        </div>
        <div class="outcome reveal">
          <div class="outcome-mark">ii.</div>
          <h3>Faster energy return</h3>
          <p>Blood restoration in the first week makes the difference.</p>
        </div>
        <div class="outcome reveal">
          <div class="outcome-mark">iii.</div>
          <h3>Less joint pain</h3>
          <p>Warmth and circulation protect against postpartum wind.</p>
        </div>
      </div>
      <div class="feature-quote reveal">
        <p class="q">
          “My milk came in so much that I ended up donating and feeding four
          babies. Any American non-Chinese mamas reading this: don’t hesitate.
          This is the stuff that really nourishes you.”
        </p>
        <p class="by">Michelle W. · Las Vegas</p>
        <p class="ctx">First-time mom, frozen delivery</p>
      </div>
    </div>
  </section>

  <!-- THE WINDOW -->
