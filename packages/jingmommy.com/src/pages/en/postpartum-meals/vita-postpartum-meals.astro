---
import Page from '@/layouts/themes/en/Page.astro'
import Svg19 from '@/assets/en/svg/en-svg-19.svg'
import Svg20 from '@/assets/en/svg/en-svg-20.svg'
import Svg21 from '@/assets/en/svg/en-svg-21.svg'
import Svg22 from '@/assets/en/svg/en-svg-22.svg'
import Svg23 from '@/assets/en/svg/en-svg-23.svg'
import Svg24 from '@/assets/en/svg/en-svg-24.svg'
import Svg25 from '@/assets/en/svg/en-svg-25.svg'
import Svg26 from '@/assets/en/svg/en-svg-26.svg'
import Svg27 from '@/assets/en/svg/en-svg-27.svg'
import Svg28 from '@/assets/en/svg/en-svg-28.svg'
import Svg29 from '@/assets/en/svg/en-svg-29.svg'
import Svg30 from '@/assets/en/svg/en-svg-30.svg'
import '@/styles/themes/en/product-delivery.css'
import { products, phones, deposits } from '@/config/index.ts'
import { usd, phoneDisplay, orderUrl, route, getPathLocale } from '@/utils/index.ts'

const locale = getPathLocale(Astro.url.pathname)
const title = "Vita Meal Plan — A Lighter Postpartum Rhythm | JingMommy"
const description =
  `The JingMommy Vita Meal plan: two full Zuo Yue Zi meals a day plus a dessert, delivered fresh daily. 30 days ${usd(products.local_vita_30d.price)}, 21 days ${usd(products.local_vita_21d.price)}, 14 days ${usd(products.local_vita_14d.price)}, or a single day ${usd(products.local_vita_1d.price)}.`


const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "JingMommy Vita Meal Plan",
    alternateName: "元氣月子餐",
    description: "Traditional Chinese postpartum (Zuo Yue Zi) recovery meals in a lighter daily rhythm — two full, cooked-from-scratch meals a day plus a dessert and a daily healing drink, delivered fresh daily. Available in 30, 21, 14, or 1-day lengths.",
    brand: { "@type": "Brand", name: "JingMommy" },
    offers: [
      { "@type": "Offer", name: "Vita Meal — 30 Days", price: String(products.local_vita_30d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Vita Meal — 21 Days", price: String(products.local_vita_21d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Vita Meal — 14 Days", price: String(products.local_vita_14d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Vita Meal — 1 Day", price: String(products.local_vita_1d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "What is the difference between the Vita Meal and the Classic Meal plan?", acceptedAnswer: { "@type": "Answer", text: "Same kitchen, same recipes, same daily delivery. The Classic plan adds breakfast — egg and porridge — and a second dessert. Vita gives you the full lunch and the full dinner, plus one dessert and the daily healing drink. The simplest way to choose: if breakfast is already covered at home, Vita fits nicely; if it isn't, Classic is the one worth having." } },
      { "@type": "Question", name: "Are two meals a day enough while I'm recovering?", acceptedAnswer: { "@type": "Answer", text: "Each Vita meal is a full recovery meal, not a smaller portion of one — lunch and dinner arrive complete, with soup, an entrée, vegetables, and rice and grains. What Vita leaves out is breakfast. For mothers whose mornings are already covered at home, or who simply don't want to eat first thing, that is the natural fit. If you know you want breakfast handled too, the Classic plan is the better choice." } },
      { "@type": "Question", name: "Can I add the herbal drinks to the Vita plan?", acceptedAnswer: { "@type": "Answer", text: `Yes — the herbal drinks are an option on the Vita plan at ${usd(products.herbal_drink.price)} a day, one cup a day, for as many days as you like. The 15 formulas are staged to follow the traditional recovery sequence, so most mothers start them on day one, alongside their meals, and keep the full arc intact from the beginning.` } },
      { "@type": "Question", name: "How does delivery work?", acceptedAnswer: { "@type": "Answer", text: "In our regular service area, meals are delivered fresh every day, aiming for your door before noon (exact times aren't guaranteed). Remote areas receive every-other-day delivery, delivery times there can't be guaranteed, and an additional delivery fee may apply. Please refrigerate meals on arrival and heat thoroughly before eating." } },
      { "@type": "Question", name: "When should I order?", acceptedAnswer: { "@type": "Answer", text: "We recommend ordering at least one month before your due date. The week your baby arrives, you will not have the bandwidth to compare plans or fill out forms — and you shouldn't have to. Your start date can be adjusted once the baby comes." } },
    ],
  },
]
---

<Page title={title} description={description} jsonLd={jsonLd}>

  <style is:global>
















