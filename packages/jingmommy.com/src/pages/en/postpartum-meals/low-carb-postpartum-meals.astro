  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">On the Table</p>
      <h2>A look at the food</h2>
      <p>Real dishes from a Low Carb week.</p>
    </div>
    <div class="gallery-grid reveal">
      <!-- IMAGE — hero dish, tall (~800×880) -->
