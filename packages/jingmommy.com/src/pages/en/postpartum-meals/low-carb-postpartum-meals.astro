---
import Base from "@/layouts/themes/en/Base.astro"
import TopBar from "@/components/themes/en/TopBar.astro"
import Footer from "@/components/themes/en/Footer.astro"
import Botanical from "@/components/themes/en/Botanical.astro"

import { phones, products } from '@/config/index.ts'
import { route, orderUrl, phoneDisplay, usd } from '@/utils/index.ts'

const title = "Low Carb Meal Plan — Zuo Yue Zi Without the Rice | JingMommy"
const description =
  `The JingMommy Low Carb Meal plan: three warm Zuo Yue Zi meals a day built on protein, vegetables, and slow-simmered soups — no rice, grains, or sweet drinks. 30 days ${usd(products.local_lowcarb_30d.price)}, 21 days ${usd(products.local_lowcarb_21d.price)}, 14 days ${usd(products.local_lowcarb_14d.price)}, or a single day ${usd(products.local_lowcarb_1d.price)}.`

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "JingMommy Low Carb Meal Plan",
    alternateName: "減醣月子餐",
    description: "Traditional Chinese postpartum (Zuo Yue Zi) recovery meals built on protein, vegetables, warming herbs, and slow-simmered soups — without rice, grains, porridge, desserts, or sweet drinks. Three warm meals a day, delivered fresh daily. Available in 30, 21, 14, or 1-day lengths.",
    brand: { "@type": "Brand", name: "JingMommy" },
    offers: [
      { "@type": "Offer", name: "Low Carb Meal — 30 Days", price: String(products.local_lowcarb_30d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Low Carb Meal — 21 Days", price: String(products.local_lowcarb_21d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Low Carb Meal — 14 Days", price: String(products.local_lowcarb_14d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Low Carb Meal — 1 Day", price: String(products.local_lowcarb_1d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "What exactly is left out of the Low Carb plan?", acceptedAnswer: { "@type": "Answer", text: "Rice and grains at lunch and dinner, the breakfast porridge, the two daily desserts, and the sweet daily healing drink. Everything else stays: the breakfast egg dish, the lunch soup, the Taiwanese postpartum soup and dinner soup, entrées, and warm vegetables at both meals — cooked from scratch and delivered fresh daily." } },
      { "@type": "Question", name: "Without the rice, is it still enough food?", acceptedAnswer: { "@type": "Answer", text: `On paper it is our leanest plan: no rice, no porridge, no dessert. But fewer items does not mean less filling. Protein and slow-simmered soups sit with you longer than a bowl of rice does, so most moms find a day of Low Carb keeps them satisfied between meals. You still get three warm meals a day, with an entrée and vegetables at both lunch and dinner. The Full Menu PDF lists every dish, and a one-day plan is ${usd(products.local_lowcarb_1d.price)}.` } },
      { "@type": "Question", name: "Is this a weight-loss plan?", acceptedAnswer: { "@type": "Answer", text: "No. This is a Zuo Yue Zi recovery plan, and it is built to nourish you — not to make you smaller. Mothers usually choose it because they are managing blood sugar, because heavy carbs do not sit well with them, or because low-carb is simply how they already eat. We do not make any weight or body-composition promises." } },
      { "@type": "Question", name: "Can I add the herbal drinks to the Low Carb plan?", acceptedAnswer: { "@type": "Answer", text: `Yes. The herbal drinks are an optional add-on at ${usd(products.herbal_drink.price * 30)} for the 30 days, one cup a day — 15 formulas that follow the traditional recovery sequence. They contain no sugar and pair naturally with this plan.` } },
      { "@type": "Question", name: "How does delivery work?", acceptedAnswer: { "@type": "Answer", text: "In our regular service area, meals are delivered fresh every day and we aim to reach your door before noon, though exact times cannot be guaranteed. Remote areas receive every-other-day delivery and an additional delivery fee may apply. Refrigerate meals on arrival and heat thoroughly before eating." } },
    ],
  },
]
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <TopBar active={route("/plans", 'en')} />

  <!-- ============ HERO ============ -->
  <section class="hero">
    <Botanical variant="hero-tl" />
    <Botanical variant="hero-br" />
    <div class="hero-inner">
      <p class="eyebrow">Zuo Yue Zi Meal Plan</p>
      <h1>Low Carb Meal</h1>
      <!-- CONFIRM: 減醣月子餐 is used on the current Meal Plans page; the Order Form / Comparison Chart list no official Chinese name for Low Carb -->
      <p class="cn-title">減醣月子餐</p>
      <p class="hero-sub">Recovery, Simplified With Purpose</p>
      <p class="lede">The low-carb lifestyle you live — <em>tailored for Zuo Yue Zi.</em></p>
      <p class="hero-price"><span class="from">30 days · 3 meals a day</span>{usd(products.local_lowcarb_30d.price)}</p>
      <div class="hero-cta">
        <a href="#pricing" class="btn btn-primary">See what's included</a>
        <a href="#taste" class="btn btn-ghost">Try a taste first</a>
      </div>
    </div>
    <div class="hero-banner reveal">
      <div class="img-slot">
        <span class="slot-icon">❀</span>
        <span class="slot-label">Hero Image</span>
        <span class="slot-hint">Wide, warm shot of a Low Carb day — soups, entrée, vegetables · ~1600 × 640</span>
      </div>
    </div>
  </section>

  <!-- ============ OPENING ============ -->
  <section class="opening">
    <div class="narrow reveal">
      <p>If low-carb is how you already live, the traditional confinement table can give you pause. All that rice, the porridge, the sweet soups — <em>beautiful, and exactly right for many mothers.</em> Just not quite the way you eat.</p>
      <p>So this plan holds onto the warmth of Zuo Yue Zi — the slow-simmered soups, the ginger and sesame oil, the herbs that follow your month — while easing back the rice, porridge, and sweets.</p>
      <p class="pull">The same Zuo Yue Zi. Just made for a low-carb life.</p>
      <p>It comes out of the same kitchen, follows the same three-stage recovery sequence, and arrives just as hot — three meals a day, built on protein, warm vegetables, and slow-simmered postpartum soups. Nothing dressed up as diet food. Just recovery food, made the way you actually eat.</p>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ DAILY ============ -->
  <section class="daily" id="daily">
    <svg class="botan daily-botan" viewBox="0 0 240 240" fill="none" aria-hidden="true">
      <g>
        <path d="M220 30 C200 70 175 100 145 122" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="180" cy="80" rx="12" ry="19" fill="#5E6B4F" opacity="0.4" transform="rotate(35 180 80)"/>
        <ellipse cx="150" cy="105" rx="10" ry="16" fill="#6E7A5C" opacity="0.38" transform="rotate(20 150 105)"/>
        <ellipse cx="115" cy="140" rx="34" ry="40" fill="#D99FB0" opacity="0.55"/>
        <path d="M115 103 C130 112 137 128 133 145 C129 160 119 170 115 172 C111 170 101 160 97 145 C93 128 100 112 115 103Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="115" cy="140" r="11" fill="#E8C46A" opacity="0.8"/>
        <circle cx="115" cy="140" r="6" fill="#A8842C" opacity="0.65"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">What Arrives Every Day</p>
        <h2>Everything that heals. Nothing that doesn't.</h2>
        <p>Every day of your thirty days, you'll receive:</p>
      </div>
      <div class="daily-grid reveal">
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish Photo</span><span class="slot-hint">Entrée with warm vegetables · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>一</span></div>
            <h3>Three low-carb meals</h3>
            <p>Protein, warm vegetables, and warming herbs at every meal — an egg dish at breakfast, then a full entrée and vegetables at both lunch and dinner. Cooked from scratch, delivered hot.</p>
          </div>
        </div>
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish Photo</span><span class="slot-hint">A slow-simmered postpartum soup · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>二</span></div>
            <h3>Healing soups at every sitting</h3>
            <p>A fish or lunch soup at midday. The traditional Taiwanese postpartum soup and a dinner soup at night. Simmered for hours, rich in collagen and minerals — this is the warmth the tradition is really built on.</p>
          </div>
        </div>
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish Photo</span><span class="slot-hint">A plated Low Carb day · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>三</span></div>
            <h3>No rice, grains, or sweet drinks</h3>
            <p>No porridge, no rice bowls, no desserts, no sugary daily drink. It's the leanest of our five plans by design — for lightness and steady energy through the day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="gallery" id="gallery">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">On the Table</p>
        <h2>A look at the food</h2>
        <p>Real dishes from a Low Carb week.</p>
      </div>
      <div class="gallery-grid reveal">
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Feature Dish</span><span class="slot-hint">Tall hero dish · ~800 × 880</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
      </div>
      <p class="gallery-note">Menus rotate across the thirty days to follow the recovery sequence.</p>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ PERSONA ============ -->
  <section class="persona">
    <svg class="botan persona-botan" viewBox="0 0 280 280" fill="none" aria-hidden="true">
      <g>
        <path d="M260 270 C240 230 215 200 185 178" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="210" cy="205" rx="12" ry="19" fill="#5E6B4F" opacity="0.35" transform="rotate(30 210 205)"/>
        <ellipse cx="150" cy="140" rx="34" ry="40" fill="#D99FB0" opacity="0.6"/>
        <path d="M150 103 C165 112 172 128 168 145 C164 160 154 170 150 172 C146 170 136 160 132 145 C128 128 135 112 150 103Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="150" cy="140" r="11" fill="#E8C46A" opacity="0.8"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="persona-grid reveal">
        <div class="persona-left">
          <p class="eyebrow">Perfect For You If…</p>
          <h2>Honor the tradition. Stay true to yourself.</h2>
          <p>The Low Carb Meal is for the mom who already lives low-carb — and wants the warmth and nourishment of Zuo Yue Zi shaped around the way she eats.</p>
        </div>
        <div class="persona-right">
          <p>Maybe you're managing postpartum blood sugar, or bloating, or an energy dip that shows up an hour after every meal — and you'd rather not spend a month working against that.</p>
          <p>Maybe low-carb is simply how you already eat, and it feels strange to abandon what works for your body at the exact moment your body needs the most from you.</p>
          <p>Or maybe you want strength, not heaviness. You believe in the tradition — you just want a version of it that <em>honors your roots and your goals at the same time</em>.</p>
          <p>Whichever you are, this plan exists so you never have to choose between the two.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ QUOTE ============ -->
  <!--
    COMPLIANCE: quote below is from the printed Low Carb brochure and is UNATTRIBUTED.
    Confirm source + written consent before launch, then attribute per the Real Stories
    Compliance Toolkit as "First name L., City, ST" — or swap for a consented quote.
  -->
  <section class="band band-cream-deep" style="overflow:hidden;position:relative">
    <Botanical variant="testimonial" />
    <div class="quote-mark">"</div>
    <div class="testi reveal">
      <p class="eyebrow">Moms Say</p>
      <p class="testi-quote">"I wanted to care for my body while keeping carbs in check — this was the perfect fit."</p>
      <p class="testi-by">— A Low Carb Meal mom</p>
    </div>
  </section>

  <!-- ============ ADD-ONS ============ -->
  <section class="addons" id="addons">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Make It Yours</p>
        <h2>Two ways to go deeper</h2>
        <p>The Low Carb plan is complete on its own. These add-ons are here if you want more.</p>
      </div>
      <div class="addon-grid reveal">
        <div class="addon-card">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">A cup of chicken essence · ~760 × 400</span></div>
          <div class="addon-body">
            <p class="tag">Recovery Booster</p>
            <h3>Slow-Simmered Chicken Essence</h3>
            <p class="cn">熬雞精</p>
            <p>The natural companion to a low-carb month — freshly brewed from <strong>premium aged hens</strong> and simmered for hours until every drop is rich with collagen, protein, and minerals, then concentrated into one small warming cup.</p>
            <p>Pure protein, no sugar, nothing to work around. Easy to sip on the days you're too tired for a full meal — it arrives ready to warm.</p>
            <p class="addon-price">{usd(products.chicken_essence.price)} / serving · add on whenever you like</p>
          </div>
        </div>
        <div class="addon-card">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">The daily herbal drinks · ~760 × 400</span></div>
          <div class="addon-body">
            <p class="tag">Optional Herbal Add-On</p>
            <h3>The 30-Day Herbal Drinks</h3>
            <p class="cn">月子藥膳</p>
            <p>The daily herbal drinks that have anchored Chinese postpartum recovery for generations — <strong>15 formulas</strong> that follow the traditional recovery sequence, stage by stage across your thirty days. One cup a day.</p>
            <p>They fit this plan naturally: no sugar, no carbs — just the herbal layer of Zuo Yue Zi that the food alone can't carry.</p>
            <p class="addon-price">{usd(products.herbal_drink.price * 30)} / 30 days · 1 cup a day</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ PRICING ============ -->
  <section class="pricing" id="pricing">
    <svg class="botan pricing-botan" viewBox="0 0 240 240" fill="none" aria-hidden="true">
      <g>
        <path d="M20 210 C40 170 65 140 95 118" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="60" cy="160" rx="12" ry="19" fill="#5E6B4F" opacity="0.4" transform="rotate(-30 60 160)"/>
        <ellipse cx="90" cy="135" rx="10" ry="16" fill="#6E7A5C" opacity="0.38" transform="rotate(-15 90 135)"/>
        <ellipse cx="125" cy="100" rx="34" ry="40" fill="#D99FB0" opacity="0.55"/>
        <path d="M125 63 C140 72 147 88 143 105 C139 120 129 130 125 132 C121 130 111 120 107 105 C103 88 110 72 125 63Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="125" cy="100" r="11" fill="#E8C46A" opacity="0.8"/>
        <circle cx="125" cy="100" r="6" fill="#A8842C" opacity="0.65"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Choose Your Length</p>
        <h2>One plan, your timeline</h2>
        <p>Three warm meals a day, delivered fresh daily. Pick the length that fits your recovery.</p>
      </div>
      <div class="price-grid reveal">
        <div class="price-card">
          <p class="mode">Every Day Includes</p>
          <h3>Low Carb Meal</h3>
          <p class="cn">減醣月子餐</p>
          <ul>
            <li><strong>Breakfast</strong> — egg dish</li>
            <li><strong>Lunch</strong> — fish soup or lunch soup, entrée, vegetables</li>
            <li><strong>Dinner</strong> — Taiwanese postpartum soup, dinner soup, entrée, vegetables</li>
            <li class="omit">No rice &amp; grains · no porridge · no desserts · no sweet healing drink</li>
            <li>Warm, cooked-from-scratch Zuo Yue Zi dishes, delivered fresh daily</li>
          </ul>
          <a href={orderUrl('local_lowcarb', 'en')} class="btn btn-primary">Order online</a>
        </div>
        <div class="price-card">
          <p class="mode">Pricing</p>
          <h3>By Length</h3>
          <p class="cn">依天數計費</p>
          <div class="tier-row feat"><span class="d">30 Days</span><span class="p">{usd(products.local_lowcarb_30d.price)}</span></div>
          <div class="tier-row"><span class="d">21 Days</span><span class="p">{usd(products.local_lowcarb_21d.price)}</span></div>
          <div class="tier-row"><span class="d">14 Days</span><span class="p">{usd(products.local_lowcarb_14d.price)}</span></div>
          <div class="tier-row"><span class="d">1 Day</span><span class="p">{usd(products.local_lowcarb_1d.price)}</span></div>
          <p class="dep">14–30 day plans: $500 deposit · balance within 3 days of first delivery. 1-day: paid in full.</p>
          <a href={orderUrl('local_lowcarb', 'en')} class="btn btn-ghost">Order online</a>
        </div>
      </div>
      <p class="price-note reveal"><strong>Optional add-ons:</strong> the 30-day herbal drinks {usd(products.herbal_drink.price * 30)} (1 cup a day) · Slow-Simmered Chicken Essence {usd(products.chicken_essence.price)}/serving · Sheng Hua Tang {usd(products.sheng_hua_tang_7.price / 7)}/day · Belly Wrap {usd(products.belly_wrap.price)} · Du Zhong Capsule {usd(products.du_zhong_capsule.price)}. Fresh daily delivery; remote areas receive every-other-day delivery and an additional delivery fee may apply.</p>
      <p class="pricing-foot">Not sure which length fits? Call us at <a href={`tel:${phones.main}`}>{phoneDisplay(phones.main)}</a> — we're happy to talk it through, no pressure.</p>
    </div>
  </section>

  <!-- ============ DOWNLOADS ============ -->
  <section class="actions" id="resources">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Review At Your Own Pace</p>
        <h2>Download the details</h2>
        <p>Prefer to look things over on your own? Grab the order form, compare every plan side by side, or browse the full menu.</p>
      </div>

      <div class="action-downloads reveal">
        <a href="//file.jingmommy.com/f/Main_Order_Form.pdf" class="action-btn">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg>
          <span class="lbl"><span class="en">Order Form <span class="pdf-tag">PDF</span></span><span class="cn">下載訂購單</span></span>
        </a>
        <a href="//file.jingmommy.com/f/Meal_Comparison_Chart.pdf" class="action-btn">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><rect x="7" y="12" width="3" height="6"/><rect x="12" y="8" width="3" height="10"/><rect x="17" y="5" width="3" height="13"/></svg>
          <span class="lbl"><span class="en">Meal Comparison Chart <span class="pdf-tag">PDF</span></span><span class="cn">餐點對照表</span></span>
        </a>
        <a href="//file.jingmommy.com/f/Menu.pdf" class="action-btn">
