---
import Page from '@/layouts/themes/en/Page.astro'
import Svg19 from '@/assets/en/svg/en-svg-19.svg'
import Svg20 from '@/assets/en/svg/en-svg-20.svg'
import Svg21 from '@/assets/en/svg/en-svg-21.svg'
import Svg22 from '@/assets/en/svg/en-svg-22.svg'
import Svg23 from '@/assets/en/svg/en-svg-23.svg'
import Svg24 from '@/assets/en/svg/en-svg-24.svg'
import Svg25 from '@/assets/en/svg/en-svg-25.svg'
import Svg26 from '@/assets/en/svg/en-svg-26.svg'
import Svg27 from '@/assets/en/svg/en-svg-27.svg'
import Svg28 from '@/assets/en/svg/en-svg-28.svg'
import Svg29 from '@/assets/en/svg/en-svg-29.svg'
import Svg30 from '@/assets/en/svg/en-svg-30.svg'
import '@/styles/themes/en/product-delivery.css'
import { products, phones, deposits } from '@/config/index.ts'
import { usd, phoneDisplay, orderUrl, route, getPathLocale } from '@/utils/index.ts'

const locale = getPathLocale(Astro.url.pathname)
const title = "Herbal Meal Plan — The Complete Zuo Yue Zi Program | JingMommy"
const description =
  `The JingMommy Herbal Meal plan: three warm Zuo Yue Zi meals a day plus the 30-day postpartum herbal drinks, included. Delivered fresh daily. 30 days ${usd(products.local_herbal_30d.price)}, 21 days ${usd(products.local_herbal_21d.price)}, 14 days ${usd(products.local_herbal_14d.price)}, or a single day ${usd(products.local_herbal_1d.price)}.`


const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "JingMommy Herbal Meal Plan",
    alternateName: "藥膳月子餐",
    description: "The complete Chinese postpartum (Zuo Yue Zi) program — three warm, cooked-from-scratch meals a day plus the JingMommy Postpartum Herbal Drink (30 days), included. Delivered fresh daily. Available in 30, 21, 14, or 1-day lengths.",
    brand: { "@type": "Brand", name: "JingMommy" },
    offers: [
      { "@type": "Offer", name: "Herbal Meal — 30 Days", price: String(products.local_herbal_30d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Herbal Meal — 21 Days", price: String(products.local_herbal_21d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Herbal Meal — 14 Days", price: String(products.local_herbal_14d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Herbal Meal — 1 Day", price: String(products.local_herbal_1d.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "What is the difference between the Herbal Meal and the Classic Meal plan?", acceptedAnswer: { "@type": "Answer", text: `Both are two halves of the same tradition. Both plans bring the same three meals a day from the same kitchen — the food that does the rebuilding. The Herbal Meal adds the other half: the JingMommy Postpartum Herbal Drink, every day for the full 30 days, included. These are not one drink repeated but a sequence of formulas that changes as the body moves through the weeks — the inner side of Zuo Yue Zi that food alone doesn't reach, already brewed and delivered with your meals. The real question is how much you want handled for you: choose Herbal to have the whole tradition taken care of, or Classic to have the meals now and add the herbal drinks by the day at ${usd(products.herbal_drink.price)}/day.` } },
      { "@type": "Question", name: "Are the herbal drinks already included, or are they an add-on?", acceptedAnswer: { "@type": "Answer", text: "On the Herbal Meal plan they are included. The 30-day JingMommy Postpartum Herbal Drink comes with the plan at no extra cost — it is the reason this plan exists. You never need to add it separately." } },
      { "@type": "Question", name: "Do the herbal drinks taste bitter?", acceptedAnswer: { "@type": "Answer", text: "A few can. Mothers tell us a couple of the formulas carry a stronger, more bitter herbal note, while most of the rest go down easily. No formula stays for long — the drinks change every couple of days as the body moves through the stages of recovery, so even one you don't love is behind you within a day or two. Zuo Yue Zi is about healing first; taste comes second. Note: our sample days do not include the herbal drinks, which are brewed for after birth and staged by week." } },
      { "@type": "Question", name: "How does delivery work?", acceptedAnswer: { "@type": "Answer", text: "In our regular service area, meals are delivered fresh every day, aiming for your door before noon (exact times aren't guaranteed). Remote areas receive every-other-day delivery, delivery times there can't be guaranteed, and an additional delivery fee may apply. Please refrigerate meals on arrival and heat thoroughly before eating." } },
      { "@type": "Question", name: "When should I order?", acceptedAnswer: { "@type": "Answer", text: "We recommend ordering at least one month before your due date. The week your baby arrives, you will not have the bandwidth to compare plans or fill out forms — and you shouldn't have to. Your start date can be adjusted once the baby comes. The Herbal Meal takes an $800 deposit on the 14, 21, and 30-day plans; the balance is due within 3 days of first delivery. The 1-day plan is paid in full." } },
    ],
  },
]
---

<Page title={title} description={description} jsonLd={jsonLd}>

