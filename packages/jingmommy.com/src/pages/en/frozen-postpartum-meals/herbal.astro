---
import Page from '@/layouts/themes/en/Page.astro'
import Svg19 from '@/assets/en/svg/en-svg-19.svg'
import Svg20 from '@/assets/en/svg/en-svg-20.svg'
import Svg21 from '@/assets/en/svg/en-svg-21.svg'
import Svg22 from '@/assets/en/svg/en-svg-22.svg'
import Svg23 from '@/assets/en/svg/en-svg-23.svg'
import Svg24 from '@/assets/en/svg/en-svg-24.svg'
import Svg25 from '@/assets/en/svg/en-svg-25.svg'
import Svg26 from '@/assets/en/svg/en-svg-26.svg'
import Svg27 from '@/assets/en/svg/en-svg-27.svg'
import Svg28 from '@/assets/en/svg/en-svg-28.svg'
import Svg29 from '@/assets/en/svg/en-svg-29.svg'
import Svg30 from '@/assets/en/svg/en-svg-30.svg'
import '@/styles/themes/en/product-frozen.css'
import { products, phones } from '@/config/index.ts'
import { usd, phoneDisplay, orderUrl, route, getPathLocale } from '@/utils/index.ts'

const locale = getPathLocale(Astro.url.pathname)
const title = "Frozen Herbal Meal — The Complete Plan, Shipped Frozen | JingMommy"
const description =
  `The complete Zuo Yue Zi plan, frozen and shipped across the 48 contiguous states: three meals a day, a restorative dessert, a daily healing drink, and the 30-day herbal drinks — 15 formulas staged across recovery. FedEx Priority Overnight included. From ${usd(products.frozen_herbal_1w.price)}/week.`


const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "JingMommy Frozen Herbal Meal",
    alternateName: "冷凍藥膳月子餐",
    description: "Complete Chinese postpartum (Zuo Yue Zi) frozen meal plan shipped across the continental US: three meals a day, a restorative dessert, a daily healing drink, and the 30-day herbal drinks — 15 formulas staged across the Mild, Warm, and Heat recovery stages. FedEx Priority Overnight shipping included to the continental US.",
    brand: { "@type": "Brand", name: "JingMommy" },
    offers: [
      { "@type": "Offer", name: "1 week", price: String(products.frozen_herbal_1w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "2 weeks", price: String(products.frozen_herbal_2w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "3 weeks", price: String(products.frozen_herbal_3w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "4 weeks", price: String(products.frozen_herbal_4w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "Is frozen really as good as fresh?", acceptedAnswer: { "@type": "Answer", text: "It's the same food from the same kitchen. Every dish is cooked fresh in our own Walnut, CA kitchen, then frozen to hold its nourishment until it reaches you. Thaw it in the refrigerator, heat it through, and it tastes the way it was cooked — warm and home-style, nothing like a supermarket TV dinner. Frozen is simply how we bring a real Zuo Yue Zi to families who live far from fresh delivery." } },
      { "@type": "Question", name: "What is the difference between Frozen Herbal and Frozen Classic?", acceptedAnswer: { "@type": "Answer", text: `Think of them as two halves of the same tradition. Both plans bring the same full menu from the same kitchen — the meals, the desserts, the Taiwanese postpartum soups — the food that does the rebuilding, staged to your recovery. The Frozen Herbal adds the other half: the 30-day herbal drinks, included. These aren't one drink repeated — they're a sequence of 15 formulas that changes as your body moves through the weeks, the inner side of Zuo Yue Zi that food alone doesn't reach, already brewed and packed with your meals so you never have to think about it. So the real question isn't the price — it's how much you want handled for you. Choose Frozen Herbal to have the whole tradition taken care of; choose Frozen Classic if you'd rather have the meals now and add the herbal drinks by the week at ${usd(products.frozen_herbal_drink_7_1w.price)}/week, or take the standalone Herbal Pack for ${usd(products.herbal_drink_pack_30d.price)}.` } },
      { "@type": "Question", name: "Will a month of frozen food fit in my freezer?", acceptedAnswer: { "@type": "Answer", text: "Longer plans ship weekly, so you're only ever storing about a week at a time. Many families keep five days in the freezer and let a couple of days thaw in the refrigerator. If space is truly tight, a small upright freezer is often enough — and it earns its keep long after the confinement month." } },
      { "@type": "Question", name: "How do I reheat the meals?", acceptedAnswer: { "@type": "Answer", text: "Thaw overnight in the refrigerator, then reheat until it's piping hot all the way through — an internal temperature of 165°F (74°C) is the safe mark for reheated food. Each day arrives pre-portioned in its own pillow-size thermal bag, so there's no meal planning, no labels to decode, and nothing to assemble — grab one bag, that's your day." } },
      { "@type": "Question", name: "What if I'm not breastfeeding?", acceptedAnswer: { "@type": "Answer", text: "We'll remove the milk-stimulating ingredients from your menu. The food still does its main job — restoring blood, warmth, and energy after birth. One honest note: fewer ingredients means fewer dishes in rotation, so the menu can feel slightly more repetitive." } },
      { "@type": "Question", name: "When should I order?", acceptedAnswer: { "@type": "Answer", text: "At least one month before your due date, if you can. The week your baby arrives, you will not have the bandwidth to compare plans or fill out forms — and you shouldn't have to. Your shipments start when you tell us the baby has arrived, not on a fixed calendar." } },
    ],
  },
]
---

<Page title={title} description={description} jsonLd={jsonLd}>

  <style is:global>
















/* ---------- IMAGE SLOTS (replace <img src> when you have real photos) ---------- */






/* Topbar */




















/* Hero */













/* Opening */





/* Daily */













/* Gallery */





/* Persona */









/* Quote */







/* Add-ons */














/* Pricing */

















/* Frozen plan pages: 4-tier weekly pricing */








/* Downloads — compact refined chips */











/* Upgrade */








/* FAQ */















/* Taste */









/* Footer */
















/* ---------- design enrichment ---------- */




/* faint seal watermark */


/* floral divider between sections */






/* editorial drop cap */


/* soft petal backing behind daily numerals */




/* section botanical accents */









  </style>

<!-- ============ HEADER (shared shell) ============ -->

<!-- ============ HERO ============ -->
<section class="hero">
  <Svg19 class="botan hero-botan-tl" aria-hidden="true" />
  <Svg20 class="botan hero-botan-br" aria-hidden="true" />
  <div class="hero-inner">
    <p class="eyebrow">Zuo Yue Zi Meal Plan · Shipped Frozen</p>
    <h1>Frozen Herbal Meal</h1>
    <p class="cn-title">冷凍藥膳月子餐</p>
    <p class="hero-sub">Complete. Rooted. Delivered.</p>
    <p class="lede">No one should face the month after birth alone. If you're far from family — far from anyone who knows how to cook for this — the complete Zuo Yue Zi tradition can still come to <em>your</em> door.</p>
    <p class="hero-price"><span class="from">4 weeks · herbal drinks included · delivered to your door</span>{usd(products.frozen_herbal_4w.price)}</p>
    <div class="hero-cta">
      <a href="#pricing" class="btn btn-primary">See what's included</a>
      <a href="#taste" class="btn btn-ghost">Try a taste first</a>
    </div>
  </div>
  <!-- HERO BANNER IMAGE — replace with a wide, warm shot of a full Frozen Herbal spread reheated + the herbal drinks (~1600×640) -->
  <div class="hero-banner reveal">
    <div class="img-slot">
      <!-- <img src="images/frozen-herbal-hero.jpg" alt="A full Frozen Herbal meal spread — soups, entrée, rice, vegetables and the herbal drinks"> -->
      <span class="slot-icon">❀</span>
      <span class="slot-label">Hero Image</span>
      <span class="slot-hint">Wide shot of a full reheated Herbal spread with the herbal drinks · ~1600 × 640</span>
    </div>
  </div>
</section>

<!-- ============ OPENING ============ -->
<section class="opening">
  <div class="narrow reveal">
    <p>A real Zuo Yue Zi has two sides: the food that rebuilds the body, and the herbal drinks that restore it from within. The Frozen Herbal Meal brings the whole of it — every meal, every dessert, a daily healing drink, and the full 30-day herbal drinks, staged the way tradition intends.</p>
    <p class="pull">The entire month, thought through and made for you — nothing to source, nothing to schedule, no formula charts to learn.</p>
    <p>We cook it all fresh in our own Walnut, CA kitchen and freeze it to hold its nourishment, then send it to your door by FedEx Priority Overnight. You thaw, heat, eat, and rest — and let your body do the rest.</p>
  </div>
</section>

<div class="floral-divider reveal">
  <span class="line"></span>
  <Svg21 aria-hidden="true" />
  <span class="line r"></span>
</div>

<!-- ============ DAILY ============ -->
<section class="daily" id="daily">
  <Svg22 class="botan daily-botan" aria-hidden="true" />
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Inside Each Day</p>
      <h2>A full day of recovery, in one bag</h2>
      <p>Your weekly shipment arrives with seven pillow-size thermal bags inside — a full day of meals in each. Pull a bag, and that's your whole day, sorted:</p>
    </div>
    <div class="daily-grid reveal">
      <div class="daily-cell">
        <!-- IMAGE — a warming soup / entrée set (~600×400) -->
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish Photo</span><span class="slot-hint">A warming soup or entrée set · ~600 × 400</span></div>
        <div class="cell-body">
          <div class="num"><span>一</span></div>
          <h3>Three full meals a day</h3>
          <p><strong>Breakfast</strong> is a wellness porridge and an egg dish. <strong>Lunch</strong> is a nourishing soup, an entrée, warm vegetables, and wellness rice. <strong>Dinner</strong> brings a Taiwanese postpartum soup — like the classic sesame oil chicken — with a tonic soup, warm vegetables, and rice. A restorative dessert and a daily healing drink round out the day.</p>
        </div>
      </div>
      <div class="daily-cell">
        <!-- IMAGE — the FedEx overnight box / thermal packaging (~600×400) -->
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Shipping</span><span class="slot-hint">The FedEx overnight box &amp; thermal packaging · ~600 × 400</span></div>
        <div class="cell-body">
          <div class="num"><span>二</span></div>
          <h3>FedEx Priority Overnight</h3>
          <p>Your week ships the fastest way there is &mdash; FedEx's top overnight service. Meals leave our kitchen and land at your door the next morning, so nothing lingers in transit and the cold chain stays unbroken across the continental US. The faster it travels, the fresher it tastes when you thaw it.</p>
        </div>
      </div>
      <div class="daily-cell">
        <!-- IMAGE — the herbal drinks (~600×400) -->
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Herbal Drinks</span><span class="slot-hint">The 30-day herbal drinks · ~600 × 400</span></div>
        <div class="cell-body">
          <div class="num"><span>三</span></div>
          <h3>The 30-day herbal drinks</h3>
          <p>What makes the Herbal plan the Herbal plan: 15 formulas that follow the traditional recovery sequence through the Mild, Warm, and Heat stages, built on herbs like Dang Gui, Chuan Xiong, Bai Shao, Shu Di, and Huang Qi.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ GALLERY ============ -->
<section class="gallery" id="gallery">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">On the Table</p>
      <h2>Packed frozen, tasting fresh</h2>
      <p>Real dishes — and the herbal drinks — from a Frozen Herbal week, once they're thawed and warmed.</p>
    </div>
    <div class="gallery-grid reveal">
      <!-- IMAGE — hero dish, tall (~800×880) -->
      <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Feature Dish</span><span class="slot-hint">Landscape feature dish · ~1200 × 800</span></div>
      <!-- IMAGE — square (~520×440) -->
      <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
      <!-- IMAGE — square (~520×440) -->
      <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
      <!-- IMAGE — square (~520×440) -->
      <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
      <!-- IMAGE — square (~520×440) -->
      <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
    </div>
    <p class="gallery-note">Menus and formulas rotate across the thirty days to follow the recovery sequence.</p>
  </div>
</section>

<div class="floral-divider reveal">
  <span class="line"></span>
  <Svg21 aria-hidden="true" />
  <span class="line r"></span>
</div>

<!-- ============ PERSONA ============ -->
<section class="persona">
  <Svg23 class="botan persona-botan" aria-hidden="true" />
  <div class="wrap">
    <div class="persona-grid reveal">
      <div class="persona-left">
        <p class="eyebrow">Perfect For You If…</p>
        <h2>The whole tradition, with no one to cook it? Solved.</h2>
        <p>The Frozen Herbal Meal is for the mom who wants the complete traditional plan — food and drinks — without figuring any of it out herself.</p>
      </div>
      <div class="persona-right">
        <p>Maybe you're states away from anyone who knows how to do this, and the version of Zuo Yue Zi you grew up hearing about felt out of reach the moment you looked at a map. Or maybe you have no interest in researching which formula belongs to which week — you just want it <em>done right</em>.</p>
        <p>The herbal drinks are the other half of Zuo Yue Zi — formulas that have anchored Chinese postpartum care for generations, staged across the weeks the way tradition intends, not poured the same way every day. Sourcing the herbs and knowing which formula belongs to which week is the hard part; here it's already brewed and packed with your meals, so you never have to think about it.</p>
        <p>You want the whole tradition taken care of — and the quiet certainty that nothing important was left out.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ QUOTE ============ -->
<section class="quote-band">
  <div class="stamp-wm" style="top:50%;left:50%;transform:translate(-50%,-50%)"></div>
  <div class="quote-mark">&ldquo;</div>
  <div class="quote-inner reveal">
    <p class="eyebrow">Moms Say</p>
    <p class="q">&ldquo;My milk came in so much that I ended up donating and feeding 4 babies. This is the real deal.&rdquo;</p>
    <p class="by">&mdash; Michelle W., Las Vegas &middot; shipped frozen</p>
  </div>
</section>

<!-- ============ ADD-ONS ============ -->
<section class="addons" id="addons">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Make It Yours</p>
      <h2>Two ways to go deeper</h2>
      <p>The Herbal plan is complete on its own. These add-ons are here if you want more.</p>
    </div>
    <div class="addon-grid reveal">
      <div class="addon-card">
        <!-- IMAGE — a cup of chicken essence (~760×400) -->
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">A cup of chicken essence · ~760 × 400</span></div>
        <div class="addon-body">
          <p class="tag">Recovery Booster</p>
          <h3>Slow-Simmered Chicken Essence</h3>
          <p class="cn">熬雞精</p>
          <p>Your go-to recovery booster — slowly simmered for hours from <strong>aged hens and white-feather chickens</strong> until every drop is rich with collagen, protein, and minerals, then concentrated into one small, warming cup.</p>
          <p>Easy to sip on the days you're too tired for a full meal. Mothers who add it tend to keep it for the whole month.</p>
          <p class="addon-price">{usd(products.frozen_chicken_essence.price)} / bowl &mdash; add to any frozen shipment</p>
        </div>
      </div>
      <div class="addon-card">
        <!-- IMAGE — Sheng Hua Tang, warm in a cup (~760×400) -->
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">Sheng Hua Tang, warm in a cup · ~760 × 400</span></div>
        <div class="addon-body">
          <p class="tag">First-Week Add-On</p>
          <h3>Sheng Hua Tang</h3>
          <p class="cn">生化湯</p>
          <p>The classical first-week formula, brewed the traditional way and taken in the earliest days after birth — the one your elders would have handed you before anything else.</p>
          <p>A ready-made 7-day course, one serving a day, timed for the earliest stage of the month. Just add it to your first shipment.</p>
          <p class="addon-price">{usd(products.frozen_herbal_drink_7_1w.price)} for 7 days &mdash; add to your first shipment</p>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="floral-divider reveal">
  <span class="line"></span>
  <Svg21 aria-hidden="true" />
  <span class="line r"></span>
</div>

<!-- ============ PRICING ============ -->
<section class="pricing" id="pricing">
  <Svg24 class="botan pricing-botan" aria-hidden="true" />
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Choose Your Length</p>
      <h2>One price, all the way to your door</h2>
      <p>Most mothers do the full four weeks — it's how the three stages are designed to unfold.</p>
    </div>
    <div class="price-grid cols4 reveal">
      <div class="price-card">
        <p class="badge"></p>
        <p class="mode">1 week</p>
        <div class="amount">{usd(products.frozen_herbal_1w.price)}</div>
        <p class="per">7 days of meals</p>
        <a href={orderUrl('frozen_herbal_1w', locale)} class="btn btn-ghost">Order online</a>
      </div>
      <div class="price-card">
        <p class="badge"></p>
        <p class="mode">2 weeks</p>
        <div class="amount">{usd(products.frozen_herbal_2w.price)}</div>
        <p class="per">14 days of meals</p>
        <a href={orderUrl('frozen_herbal_2w', locale)} class="btn btn-ghost">Order online</a>
      </div>
      <div class="price-card">
        <p class="badge"></p>
        <p class="mode">3 weeks</p>
        <div class="amount">{usd(products.frozen_herbal_3w.price)}</div>
        <p class="per">21 days of meals</p>
        <a href={orderUrl('frozen_herbal_3w', locale)} class="btn btn-ghost">Order online</a>
      </div>
      <div class="price-card featured">
        <p class="badge">Most chosen</p>
        <p class="mode">4 weeks</p>
        <div class="amount">{usd(products.frozen_herbal_4w.price)}</div>
        <p class="per">28 days of meals</p>
        <a href={orderUrl('frozen_herbal_4w', locale)} class="btn btn-primary">Order online</a>
      </div>
    </div>
    <p class="pricing-foot">Every length includes the full daily menu with herbal drinks, with FedEx Priority Overnight delivery to the 48 contiguous states. One-week plans ship once; longer plans ship weekly; we deliver to FedEx-serviceable addresses only (not Alaska or Hawaii). In a state bordering California? Special weekly pricing may apply &mdash; call <a href={`tel:${phones.main}`}>{phoneDisplay(phones.main)}</a>.</p>
  </div>
</section>

<!-- ============ DOWNLOADS (shared block) ============ -->
<section class="actions" id="resources">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Review At Your Own Pace</p>
      <h2>Download the details</h2>
      <p>Prefer to look things over on your own? Grab the order form, compare every frozen plan side by side, or browse the full menu.</p>
    </div>
    <div class="action-downloads reveal">
      <a href="https://file.jingmommy.com/f/Frozen_Meal_Order_Form.pdf" class="action-btn">
        <Svg25 class="ico" />
        <span class="lbl"><span class="en">Order Form <span class="pdf-tag">PDF</span></span><span class="cn">下載訂購單</span></span>
      </a>
      <a href="https://file.jingmommy.com/f/Frozen_Meal_Comparison_Chart.pdf" class="action-btn">
        <Svg26 class="ico" />
        <span class="lbl"><span class="en">Frozen Plan Comparison <span class="pdf-tag">PDF</span></span><span class="cn">冷凍餐對照表</span></span>
      </a>
      <a href="https://file.jingmommy.com/f/Frozen_Sample_Menu.pdf" class="action-btn">
        <Svg27 class="ico" />
        <span class="lbl"><span class="en">Full Menu <span class="pdf-tag">PDF</span></span><span class="cn">菜單</span></span>
      </a>
    </div>
  </div>
</section>

<!-- ============ UPGRADE / CROSS-SELL ============ -->
<section class="upgrade">
  <div class="upgrade-inner reveal">
    <p class="eyebrow">Want the Food Without the Drinks?</p>
    <h2>The Frozen Classic Meal &mdash; {usd(products.frozen_classic_4w.price)}</h2>
    <p>Same kitchen, same three meals, a dessert, and a daily healing drink &mdash; without the herbal drinks. You can always add them later at {usd(products.frozen_herbal_drink_7_1w.price)}/week, or take the standalone Herbal Pack for {usd(products.herbal_drink_pack_30d.price)}.</p>
    <a href={route("/plans/frozen-classic", locale)} class="btn btn-primary">Explore the Frozen Classic Meal</a>
  </div>
</section>

<!-- ============ FAQ ============ -->
<section class="faq-band" id="faq">
  <Svg28 class="botan faq-botan" aria-hidden="true" />
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Good Questions</p>
      <h2>Before you decide</h2>
    </div>
    <div class="faq-list reveal">
      <details class="faq-item">
        <summary>Is frozen really as good as fresh?</summary>
        <div class="faq-answer">
          <p>It's the same food from the same kitchen. Every dish is cooked fresh in our own Walnut, CA kitchen, then frozen to hold its nourishment until it reaches you. Thaw it in the refrigerator, heat it through, and it tastes the way it was cooked &mdash; warm and home-style, nothing like a supermarket TV dinner. Frozen is simply how we bring a real Zuo Yue Zi to families who live far from fresh delivery.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>What's the difference between Frozen Herbal and Frozen Classic?</summary>
        <div class="faq-answer">
          <p>Think of them as two halves of the same tradition. Both plans bring the same full menu from the same kitchen &mdash; the meals, the desserts, the Taiwanese postpartum soups &mdash; the food that does the rebuilding, staged to your recovery.</p>
          <p>The Frozen Herbal adds the other half: the 30-day herbal drinks, included. These aren't one drink repeated &mdash; they're a sequence of 15 formulas that changes as your body moves through the weeks, the inner side of Zuo Yue Zi that food alone doesn't reach, already brewed and packed with your meals so you never have to think about it.</p>
          <p>So the real question isn't the price &mdash; it's how much you want handled for you. Choose <em>Frozen Herbal</em> to have the whole tradition taken care of; choose <em>Frozen Classic</em> if you'd rather have the meals now and add the herbal drinks by the week at {usd(products.frozen_herbal_drink_7_1w.price)}/week, or take the standalone <em>Herbal Pack</em> for {usd(products.herbal_drink_pack_30d.price)}.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Will a month of frozen food fit in my freezer?</summary>
        <div class="faq-answer">
          <p>Longer plans ship weekly, so you're only ever storing about a week at a time. Many families keep five days in the freezer and let a couple of days thaw in the refrigerator. If space is truly tight, a small upright freezer is often enough &mdash; and it earns its keep long after the confinement month.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>How do I reheat the meals?</summary>
        <div class="faq-answer">
          <p>Thaw overnight in the refrigerator, then reheat until it's piping hot all the way through &mdash; an internal temperature of 165&deg;F (74&deg;C) is the safe mark for reheated food. Each day arrives pre-portioned in its own pillow-size thermal bag, so there's no meal planning, no labels to decode, and nothing to assemble &mdash; grab one bag, that's your day.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>What if I'm not breastfeeding?</summary>
        <div class="faq-answer">
          <p>We'll remove the milk-stimulating ingredients from your menu. The food still does its main job &mdash; restoring blood, warmth, and energy after birth. One honest note: fewer ingredients means fewer dishes in rotation, so the menu can feel slightly more repetitive.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>When should I order?</summary>
        <div class="faq-answer">
          <p>At least one month before your due date, if you can. The week your baby arrives, you will not have the bandwidth to compare plans or fill out forms &mdash; and you shouldn't have to. Your shipments start when you tell us the baby has arrived, not on a fixed calendar.</p>
        </div>
      </details>
    </div>
  </div>
</section>

<!-- ============ TASTE CTA ============ -->
<section class="taste" id="taste">
  <Svg29 class="botan taste-botan-l" aria-hidden="true" />
  <Svg30 class="botan taste-botan-r" aria-hidden="true" />
  <div class="taste-inner reveal">
    <p class="eyebrow">Not Sure Yet?</p>
    <h2>Taste before you commit.</h2>
    <p>Most mothers who ship frozen tried a sample first. Eight dishes from our real recipes, in the same packaging materials we use every day &mdash; enough to taste the food and try the reheating before you commit.</p>
    <div class="taste-cta">
      <a href={orderUrl('frozen_classic_sample_8item', locale)} class="btn btn-primary">Order a frozen sample &mdash; {usd(products.frozen_classic_sample_8item.price)}</a>
      <a href={route("/contact", locale)} class="btn btn-ghost">Contact us</a>
    </div>
    <p class="taste-note">Ships FedEx overnight across the continental US &mdash; or call {phoneDisplay(phones.main)}. We're usually around later than you'd expect.</p>
  </div>
</section>

<!-- ============ FOOTER (shared shell) ============ -->

<script is:inline>
(function(){
  var els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(en){
      if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}
    });
  },{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
  els.forEach(function(e){io.observe(e);});
  document.querySelectorAll('#nav a').forEach(function(a){
    a.addEventListener('click',function(){document.getElementById('nav').classList.remove('open');});
  });
})();
</script>
</Page>
