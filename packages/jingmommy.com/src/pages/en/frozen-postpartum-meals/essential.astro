---
import Base from "@/layouts/themes/en/Base.astro"
import TopBar from "@/components/themes/en/TopBar.astro"
import Footer from "@/components/themes/en/Footer.astro"
import Botanical from "@/components/themes/en/Botanical.astro"

import { phones, products } from '@/config/index.ts'
import { route, orderUrl, phoneDisplay, usd } from '@/utils/index.ts'

const title = "Frozen Essential Meal — Lunch & Dinner, 5 Days a Week | JingMommy"
const description =
  `The two anchor meals of Zuo Yue Zi — slow-cooked lunch and dinner sets, five days a week, frozen and shipped across the 48 contiguous states. 20 meal days over four weeks. FedEx Priority Overnight included. From ${usd(products.frozen_essential_1w.price)}/week.`

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "JingMommy Frozen Essential Meal",
    alternateName: "冷凍活力月子餐",
    description: "Chinese postpartum (Zuo Yue Zi) frozen meal plan shipped across the continental US: full lunch and dinner sets with a dessert, five days a week — 20 meal days across four weeks, with two rest days each week. Herbal drinks and chicken essence available as add-ons. FedEx Priority Overnight shipping included to the continental US.",
    brand: { "@type": "Brand", name: "JingMommy" },
    offers: [
      { "@type": "Offer", name: "Frozen Essential Meal — 1 Week", price: String(products.frozen_essential_1w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Frozen Essential Meal — 2 Weeks", price: String(products.frozen_essential_2w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Frozen Essential Meal — 3 Weeks", price: String(products.frozen_essential_3w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
      { "@type": "Offer", name: "Frozen Essential Meal — 4 Weeks", price: String(products.frozen_essential_4w.price), priceCurrency: "USD", availability: "https://schema.org/InStock" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "Is frozen really as good as fresh?", acceptedAnswer: { "@type": "Answer", text: "It's the same food from the same kitchen. Every dish is cooked fresh in our own Walnut, CA kitchen, then frozen to hold its nourishment until it reaches you. Thaw it in the refrigerator, heat it through, and it tastes the way it was cooked — warm and home-style, nothing like a supermarket TV dinner. Frozen is simply how we bring a real Zuo Yue Zi to families who live far from fresh delivery." } },
      { "@type": "Question", name: "What do I eat on the two free days?", acceptedAnswer: { "@type": "Answer", text: "Whatever works for you. Some mothers keep it warming and simple at home; some let family take over; some just want a break. If you'd rather have every day covered, the Frozen Classic Meal runs seven days a week." } },
      { "@type": "Question", name: "Is two meals a day enough for recovery?", acceptedAnswer: { "@type": "Answer", text: "The Essential covers the two anchor meals of the tradition — the slow-cooked soups and warming dishes at lunch and dinner. It's designed for mothers who have breakfast handled or prefer a lighter rhythm. If you want the full sunrise-to-bedtime plan, the Classic or Herbal plans are the better fit — and we'll tell you that honestly if you ask." } },
      { "@type": "Question", name: "Can I add the herbal drinks or healing drink later?", acceptedAnswer: { "@type": "Answer", text: `Yes. The herbal drinks can join any weekly shipment at ${usd(products.frozen_herbal_drink_7_1w.price)}/week, and the healing drink can be added as an option — just contact us and we'll arrange it with your next delivery.` } },
      { "@type": "Question", name: "Will a month of frozen food fit in my freezer?", acceptedAnswer: { "@type": "Answer", text: "Longer plans ship weekly, so you're only ever storing about a week at a time. Many families keep five days in the freezer and let a couple of days thaw in the refrigerator. If space is truly tight, a small upright freezer is often enough — and it earns its keep long after the confinement month." } },
      { "@type": "Question", name: "How do I reheat the meals?", acceptedAnswer: { "@type": "Answer", text: "Thaw overnight in the refrigerator, then reheat until it's piping hot all the way through — an internal temperature of 165°F (74°C) is the safe mark for reheated food. Each day arrives pre-portioned in its own pillow-size thermal bag, so there's no meal planning, no labels to decode, and nothing to assemble — grab one bag, that's your day." } },
      { "@type": "Question", name: "When should I order?", acceptedAnswer: { "@type": "Answer", text: "At least one month before your due date, if you can. The week your baby arrives, you will not have the bandwidth to compare plans or fill out forms — and you shouldn't have to. Your shipments start when you tell us the baby has arrived, not on a fixed calendar." } },
    ],
  },
]
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <TopBar active={route("/plans", 'en')} />

  <!-- ============ HERO ============ -->
  <section class="hero">
    <Botanical variant="hero-tl" />
    <Botanical variant="hero-br" />
    <div class="hero-inner">
      <p class="eyebrow">Zuo Yue Zi Meal Plan · Shipped Frozen</p>
      <h1>Frozen Essential Meal</h1>
      <p class="cn-title">冷凍活力月子餐</p>
      <p class="hero-sub">Light. Flexible. Nourishing.</p>
      <p class="lede">Recovery doesn't have to run on someone else's schedule. The two meals that matter most — the slow-cooked soups and warming dishes — five days a week, frozen and shipped to <em>your</em> door. The other two days are yours.</p>
      <p class="hero-price"><span class="from">20 days over 4 weeks · delivered to your door</span>{usd(products.frozen_essential_4w.price)}</p>
      <div class="hero-cta">
        <a href="#pricing" class="btn btn-primary">See what's included</a>
        <a href="#taste" class="btn btn-ghost">Try a taste first</a>
      </div>
    </div>
    <div class="hero-banner reveal">
      <div class="img-slot">
        <span class="slot-icon">❀</span>
        <span class="slot-label">Hero Image</span>
        <span class="slot-hint">Wide shot of a reheated Essential lunch &amp; dinner spread · ~1600 × 640</span>
      </div>
    </div>
  </section>

  <!-- ============ OPENING ============ -->
  <section class="opening">
    <div class="narrow reveal">
      <p>Some days you want every meal taken care of; some days you'd rather keep a little room to breathe. The Frozen Essential Meal is built for exactly that — the two meals that carry the most of the tradition, ready whenever you want them.</p>
      <p class="pull">Slow-cooked soups and warming dishes at lunch and dinner, five days a week — with two days that are entirely yours.</p>
      <p>Each meal is cooked fresh in our own Walnut, CA kitchen and frozen to hold its nourishment, then sent to your door by FedEx Priority Overnight. Light, flexible recovery food that fits the life you're actually living.</p>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ DAILY ============ -->
  <section class="daily" id="daily">
    <svg class="botan daily-botan" viewBox="0 0 240 240" fill="none" aria-hidden="true">
      <g>
        <path d="M220 30 C200 70 175 100 145 122" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="180" cy="80" rx="12" ry="19" fill="#5E6B4F" opacity="0.4" transform="rotate(35 180 80)"/>
        <ellipse cx="150" cy="105" rx="10" ry="16" fill="#6E7A5C" opacity="0.38" transform="rotate(20 150 105)"/>
        <ellipse cx="115" cy="140" rx="34" ry="40" fill="#D99FB0" opacity="0.55"/>
        <path d="M115 103 C130 112 137 128 133 145 C129 160 119 170 115 172 C111 170 101 160 97 145 C93 128 100 112 115 103Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="115" cy="140" r="11" fill="#E8C46A" opacity="0.8"/>
        <circle cx="115" cy="140" r="6" fill="#A8842C" opacity="0.65"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Inside Each Meal Day</p>
        <h2>Two meals and a dessert, five days a week</h2>
        <p>Your weekly shipment arrives with five pillow-size thermal bags inside — one meal day in each. Pull a bag: lunch, dinner, and dessert, done:</p>
      </div>
      <div class="daily-grid reveal">
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Lunch &amp; Dinner</span><span class="slot-hint">A full lunch or dinner set · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>一</span></div>
            <h3>Lunch, dinner, and a dessert</h3>
            <p><strong>Lunch</strong> is a nourishing soup, an entrée, warm vegetables, and wellness rice. <strong>Dinner</strong> is the heart of it — a Taiwanese postpartum soup like the classic sesame oil chicken, a tonic soup, warm vegetables, and rice — finished with a <strong>restorative dessert</strong>.</p>
          </div>
        </div>
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Shipping</span><span class="slot-hint">The FedEx overnight box &amp; thermal packaging · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>二</span></div>
            <h3>FedEx Priority Overnight</h3>
            <p>Your week ships the fastest way there is — FedEx's top overnight service. Meals leave our kitchen and land at your door the next morning, so nothing lingers in transit and the cold chain stays unbroken across the continental US. The faster it travels, the fresher it tastes when you thaw it.</p>
          </div>
        </div>
        <div class="daily-cell">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Rest Days</span><span class="slot-hint">Two free days a week · ~600 × 400</span></div>
          <div class="cell-body">
            <div class="num"><span>三</span></div>
            <h3>Two days that are yours</h3>
            <p>On the two off days, eat with family, let someone cook for you, or just have what sounds good. Recovery doesn't have to mean every meal is prescribed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="gallery" id="gallery">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">On the Table</p>
        <h2>Packed frozen, tasting fresh</h2>
        <p>Real lunch and dinner sets from a Frozen Essential week, once they're thawed and warmed.</p>
      </div>
      <div class="gallery-grid reveal">
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Feature Dish</span><span class="slot-hint">Landscape feature dish · ~1200 × 800</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
        <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Dish</span><span class="slot-hint">~520 × 440</span></div>
      </div>
      <p class="gallery-note">Menus rotate across the days so the month never feels repetitive.</p>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ PERSONA ============ -->
  <section class="persona">
    <svg class="botan persona-botan" viewBox="0 0 280 280" fill="none" aria-hidden="true">
      <g>
        <path d="M260 270 C240 230 215 200 185 178" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="210" cy="205" rx="12" ry="19" fill="#5E6B4F" opacity="0.35" transform="rotate(30 210 205)"/>
        <ellipse cx="150" cy="140" rx="34" ry="40" fill="#D99FB0" opacity="0.6"/>
        <path d="M150 103 C165 112 172 128 168 145 C164 160 154 170 150 172 C146 170 136 160 132 145 C128 128 135 112 150 103Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="150" cy="140" r="11" fill="#E8C46A" opacity="0.8"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="persona-grid reveal">
        <div class="persona-left">
          <p class="eyebrow">Perfect For You If…</p>
          <h2>Recovery food that fits around your life.</h2>
          <p>The Essential is for the mom who knows what she needs — and what she doesn't.</p>
        </div>
        <div class="persona-right">
          <p>Maybe this isn't your first month, and you already know the anchor meals are what matter — not a schedule that accounts for every waking hour. Or maybe breakfast is already handled, and what you want is the food no one around you can make: the slow-simmered soups, the warming dishes, <em>done right</em>.</p>
          <p>It's a light, flexible plan — and the easiest to build on. Add the herbal drinks or chicken essence whenever you want more.</p>
          <p>You know what you need — enough support to recover well, and enough freedom to still feel like yourself.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ QUOTE ============ -->
  <section class="band band-cream-deep" style="overflow:hidden;position:relative">
    <Botanical variant="testimonial" />
    <div class="quote-mark">"</div>
    <div class="testi reveal">
      <p class="eyebrow">Moms Say</p>
      <p class="testi-quote">"I don't speak Chinese, but the team answered all my questions in English. She made me feel so cared for."</p>
      <p class="testi-by">— Michelle N., SoCal</p>
    </div>
  </section>

  <!-- ============ ADD-ONS ============ -->
  <section class="addons" id="addons">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Make It Yours</p>
        <h2>Start light. Add what you need.</h2>
        <p>The Essential is built to be a foundation. Add the herbal drinks or chicken essence whenever you want more.</p>
      </div>
      <div class="addon-grid reveal">
        <div class="addon-card">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">The 30-day herbal drinks · ~760 × 400</span></div>
          <div class="addon-body">
            <p class="tag">Herbal Add-On</p>
            <h3>The 30-Day Herbal Drinks</h3>
            <p class="cn">月子藥膳</p>
            <p>The daily herbal drinks that have anchored Chinese postpartum recovery for generations — <strong>15 formulas</strong> that follow the traditional recovery sequence through the Mild, Warm, and Heat stages of your month.</p>
            <p>They come included with the <a href={route("/frozen-postpartum-meals/herbal", 'en')} style="color:var(--accent-deep)">Frozen Herbal Meal</a>, or you can add them to this plan.</p>
            <p class="addon-price">{usd(products.frozen_herbal_drink_7_1w.price)}/week with your frozen shipments · or the standalone Herbal Pack, {usd(products.herbal_drink_pack_30d.price)}</p>
          </div>
        </div>
        <div class="addon-card">
          <div class="img-slot"><span class="slot-icon">❀</span><span class="slot-label">Add-on Photo</span><span class="slot-hint">A cup of chicken essence · ~760 × 400</span></div>
          <div class="addon-body">
            <p class="tag">Recovery Booster</p>
            <h3>Slow-Simmered Chicken Essence</h3>
            <p class="cn">熬雞精</p>
            <p>Your go-to recovery booster — slowly simmered for hours from <strong>aged hens and white-feather chickens</strong> until every drop is rich with collagen, protein, and minerals, then concentrated into one small, warming cup.</p>
            <p>Easy to sip on the days you're too tired for a full meal. Mothers who add it tend to keep it for the whole month.</p>
            <p class="addon-price">{usd(products.frozen_chicken_essence.price)} / bowl — add to any frozen shipment</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="floral-divider reveal">
    <span class="line"></span>
    <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><g><circle cx="20" cy="20" r="4" fill="#A8842C" opacity="0.85"/><ellipse cx="20" cy="9" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="20" cy="31" rx="4.5" ry="7" fill="#C77D7D" opacity="0.7"/><ellipse cx="9" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="31" cy="20" rx="7" ry="4.5" fill="#C77D7D" opacity="0.7"/><ellipse cx="12" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 12 12)"/><ellipse cx="28" cy="12" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 28 12)"/><ellipse cx="12" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(45 12 28)"/><ellipse cx="28" cy="28" rx="5" ry="6" fill="#D99FB0" opacity="0.6" transform="rotate(-45 28 28)"/></g></svg>
    <span class="line r"></span>
  </div>

  <!-- ============ PRICING ============ -->
  <section class="pricing" id="pricing">
    <svg class="botan pricing-botan" viewBox="0 0 240 240" fill="none" aria-hidden="true">
      <g>
        <path d="M20 210 C40 170 65 140 95 118" stroke="#5E6B4F" stroke-width="2" fill="none" opacity="0.6"/>
        <ellipse cx="60" cy="160" rx="12" ry="19" fill="#5E6B4F" opacity="0.4" transform="rotate(-30 60 160)"/>
        <ellipse cx="90" cy="135" rx="10" ry="16" fill="#6E7A5C" opacity="0.38" transform="rotate(-15 90 135)"/>
        <ellipse cx="125" cy="100" rx="34" ry="40" fill="#D99FB0" opacity="0.55"/>
        <path d="M125 63 C140 72 147 88 143 105 C139 120 129 130 125 132 C121 130 111 120 107 105 C103 88 110 72 125 63Z" fill="#C77D7D" opacity="0.5"/>
        <circle cx="125" cy="100" r="11" fill="#E8C46A" opacity="0.8"/>
        <circle cx="125" cy="100" r="6" fill="#A8842C" opacity="0.65"/>
      </g>
    </svg>
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Choose Your Length</p>
        <h2>One price, all the way to your door</h2>
        <p>The full plan runs 20 meal days across four weeks — five days on, two days yours.</p>
      </div>
      <div class="price-grid cols4 reveal">
        <div class="price-card">
          <p class="badge">&nbsp;</p>
          <p class="mode">1 week</p>
          <div class="amount">{usd(products.frozen_essential_1w.price)}</div>
          <p class="per">5 meal days</p>
          <a href={orderUrl('frozen_essential', 'en')} class="btn btn-ghost">Order online</a>
        </div>
        <div class="price-card">
          <p class="badge">&nbsp;</p>
          <p class="mode">2 weeks</p>
          <div class="amount">{usd(products.frozen_essential_2w.price)}</div>
          <p class="per">10 meal days</p>
          <a href={orderUrl('frozen_essential', 'en')} class="btn btn-ghost">Order online</a>
        </div>
        <div class="price-card">
          <p class="badge">&nbsp;</p>
          <p class="mode">3 weeks</p>
          <div class="amount">{usd(products.frozen_essential_3w.price)}</div>
          <p class="per">15 meal days</p>
          <a href={orderUrl('frozen_essential', 'en')} class="btn btn-ghost">Order online</a>
        </div>
        <div class="price-card featured">
          <p class="badge">Most chosen</p>
          <p class="mode">4 weeks</p>
          <div class="amount">{usd(products.frozen_essential_4w.price)}</div>
          <p class="per">20 meal days</p>
          <a href={orderUrl('frozen_essential', 'en')} class="btn btn-primary">Order online</a>
        </div>
      </div>
      <p class="pricing-foot">Every length includes lunch, dinner, and a dessert, five days a week, with FedEx Priority Overnight delivery to the 48 contiguous states. One-week plans ship once; longer plans ship weekly; we deliver to FedEx-serviceable addresses only (not Alaska or Hawaii). In a state bordering California? Special weekly pricing may apply — call <a href={`tel:${phones.main}`}>{phoneDisplay(phones.main)}</a>.</p>
    </div>
  </section>

  <!-- ============ DOWNLOADS ============ -->
  <section class="actions" id="resources">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Review At Your Own Pace</p>
        <h2>Download the details</h2>
        <p>Prefer to look things over on your own? Grab the order form, compare every frozen plan side by side, or browse the full menu.</p>
      </div>

      <div class="action-downloads reveal">
        <a href="//file.jingmommy.com/f/Frozen_Meal_Order_Form.pdf" class="action-btn">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5M12 15V3"/></svg>
          <span class="lbl"><span class="en">Order Form <span class="pdf-tag">PDF</span></span><span class="cn">下載訂購單</span></span>
        </a>
        <a href="//file.jingmommy.com/f/Frozen_Meal_Comparison_Chart.pdf" class="action-btn">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><rect x="7" y="12" width="3" height="6"/><rect x="12" y="8" width="3" height="10"/><rect x="17" y="5" width="3" height="13"/></svg>
          <span class="lbl"><span class="en">Frozen Plan Comparison <span class="pdf-tag">PDF</span></span><span class="cn">冷凍餐對照表</span></span>
        </a>
        <a href="//file.jingmommy.com/f/Menu.pdf" class="action-btn">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h0a2 2 0 0 0 2-2V2M5 2v20M15 2c-1.5 0-3 1.5-3 4s1.5 4 3 4v12"/></svg>
