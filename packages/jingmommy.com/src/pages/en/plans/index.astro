---
import Base from "@/layouts/themes/en/Base.astro"
import TopBar from "@/components/en/TopBar.astro"
import Footer from "@/components/en/Footer.astro"
import PageHero from "@/components/en/PageHero.astro"
import { brand, route, orderUrl, orderSampleUrl, planOrderUrls } from "@/config/en.ts"
import { products, usd } from '@/client.config.ts'

const title =
  "Meal Plans — Chinese Postpartum (Zuo Yue Zi) Delivery — JingMommy"
const description =
  `Five fresh and four frozen 30-day Chinese postpartum meal plans, from ${usd(products.local_easy_15d.price)}. Same kitchen, same three-stage Zuo Yue Zi program — delivered fresh in SoCal or shipped frozen nationwide.`

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "JingMommy Meal Plans",
    itemListElement: [
      {
        "@type": "Product",
        name: "Herbal Meal",
        offers: { "@type": "Offer", price: "2890", priceCurrency: "USD" },
      },
      {
        "@type": "Product",
        name: "Classic Meal",
        offers: { "@type": "Offer", price: "2590", priceCurrency: "USD" },
      },
      {
        "@type": "Product",
        name: "Vita Meal",
        offers: { "@type": "Offer", price: "2299", priceCurrency: "USD" },
      },
      {
        "@type": "Product",
        name: "Low Carb Meal",
        offers: { "@type": "Offer", price: "1999", priceCurrency: "USD" },
      },
      {
        "@type": "Product",
        name: "Easy Meal",
        offers: { "@type": "Offer", price: "1550", priceCurrency: "USD" },
      },
    ].map((p, i) => ({ "@type": "ListItem", position: i + 1, item: p })),
  },
]
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <TopBar active={route("/plans")} />

  <PageHero
    eyebrow="Meal Plans"
    title="Find the plan that fits your recovery."
    lede="Same kitchen, same recipes, same three-stage program — delivered fresh, or shipped frozen."
  >
    <div class="tabs hero-tabs">
      <button class="tab active" data-tab="fresh">
        <div class="tab-title">Fresh Daily</div>
        <div class="tab-sub">Same-day delivery in Southern California</div>
      </button>
      <button class="tab" data-tab="frozen">
        <div class="tab-title">Frozen Nationwide</div>
        <div class="tab-sub">
          FedEx Priority Overnight to the continental US
        </div>
      </button>
    </div>
  </PageHero>

  <!-- THE PLANS -->
  <section class="band band-paper" id="plans" style="padding-top:40px">
    <div class="wrap">
      <!-- FRESH -->
      <div class="tab-content active" id="tab-fresh">
        <p class="tab-intro">
          Fresh delivery covers most areas of Southern California.
          <a href={`${route("/contact")}#delivery`}>Check your zip code →</a>
        </p>
        <div class="plan-grid">
          <div class="plan-card">
            <div class="plan-name">Herbal Meal</div>
            <div class="plan-chinese">藥膳月子餐</div>
            <p class="plan-persona">
              If you’re going to do this, do it the full way. The complete
              program — every meal and the daily herbal drinks that have
              anchored Chinese postpartum recovery for two thousand years.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals a day</strong></div>
              <div>Daily herbal drinks <strong>included</strong></div>
            </div>
            <div class="plan-price">{usd(products.local_herbal_30d.price)}</div>
            <div class="plan-tag">30 days</div>
            <a href={planOrderUrls.herbal} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Classic Meal</div>
            <div class="plan-chinese">精緻月子餐</div>
            <p class="plan-persona">
              Three warm meals a day, ready when you are. Recovery food cooked
              the way it should be cooked, delivered to your door — so the only
              decision you make at lunchtime is when to eat.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals a day</strong></div>
              <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
            </div>
            <div class="plan-price">{usd(products.local_classic_30d.price)}</div>
            <div class="plan-tag">30 days</div>
            <a href={planOrderUrls.classic} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Vita Meal</div>
            <div class="plan-chinese">元氣月子餐</div>
            <p class="plan-persona">
              You don’t need to be eating from the moment you wake up. Lunch,
              dinner, and a dessert — full recovery meals in a lighter daily
              rhythm, for the days when breakfast is already handled or you just
              don’t want one.
            </p>
            <div class="plan-spec">
              <div><strong>2 meals a day + dessert</strong></div>
              <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
            </div>
            <div class="plan-price">{usd(products.local_vita_30d.price)}</div>
            <div class="plan-tag">30 days</div>
            <a href={planOrderUrls.vita} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Low Carb Meal</div>
            <div class="plan-chinese">減醣月子餐</div>
            <p class="plan-persona">
              You can recover and stay on plan. Three meals a day with the rice,
              porridge, and sweets set aside — for moms managing blood sugar,
              weight, or staying low-carb / keto-aware through postpartum.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals a day</strong></div>
              <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
            </div>
            <div class="plan-price">{usd(products.local_lowcarb_30d.price)}</div>
            <div class="plan-tag">30 days</div>
            <a href={planOrderUrls.lowCarb} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Easy Meal</div>
            <div class="plan-chinese">輕享月子餐</div>
            <p class="plan-persona">
              New to Chinese postpartum food and not sure if you want to commit
              to thirty straight days? Start here. Real recovery meals delivered
              every other day — enough to feel the difference, light enough to
              ease into.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals a day, delivered 15 times</strong></div>
              <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
            </div>
            <div class="plan-price">{usd(products.local_easy_15d.price)}</div>
            <div class="plan-tag">30 days</div>
            <a href={planOrderUrls.easy} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card helper-card">
            <h4>Not sure which one?</h4>
            <p>
              Most mothers start with Classic or Herbal. If you’ve never had
              Chinese postpartum food before, the easiest way to decide is to
              try a sample first.
            </p>
            <a href={route("/sample")} class="helper-link"
              >→ Try the {usd(products.local_classic_sample_1d.price)} Local Tasting</a
            >
            <a href={brand.phoneHref} class="helper-link"
              >→ Or call us at {brand.phone}</a
            >
          </div>
        </div>
      </div>

      <!-- FROZEN -->
      <div class="tab-content" id="tab-frozen">
        <p class="tab-intro">
          If you’re outside our delivery area, you’ve probably been wondering
          whether real Zuo Yue Zi recovery is even possible from where you are.
          It is. Four plans, our same kitchen, frozen and shipped overnight to
          the continental US. Shipping included.
          <br /><span class="tab-intro-note"
            >If you’re in California, special pricing may apply — call us at <strong
              >{brand.phone}</strong
            >.</span
          >
        </p>
        <div class="plan-grid">
          <div class="plan-card">
            <div class="plan-name">Frozen Herbal Meal</div>
            <div class="plan-chinese">冷凍藥膳月子餐</div>
            <p class="plan-persona">
              You just did one of the hardest things a body can do. The next 30
              days deserve a real plan, not whatever happens to be in the
              fridge. The complete program — every meal and the daily herbal
              drinks.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals + dessert + herbal drink</strong></div>
            </div>
            <div class="plan-price">{usd(products.frozen_herbal_4w.price)}</div>
            <div class="plan-tag">
              4 weeks · FedEx Priority Overnight shipping included
            </div>
            <a href={planOrderUrls.frozenHerbal} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Frozen Classic Meal</div>
            <div class="plan-chinese">冷凍精緻月子餐</div>
            <p class="plan-persona">
              Three meals a day, every day, sent to your door — wherever your
              door is. The food does the work; you just heat and eat.
            </p>
            <div class="plan-spec">
              <div><strong>3 meals + dessert</strong> (no herbal drink)</div>
            </div>
            <div class="plan-price">{usd(products.frozen_classic_4w.price)}</div>
            <div class="plan-tag">
              4 weeks · FedEx Priority Overnight shipping included
            </div>
            <a href={planOrderUrls.frozenClassic} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Frozen Essential Meal</div>
            <div class="plan-chinese">冷凍活力月子餐</div>
            <p class="plan-persona">
              Maybe you’ve done this before. Maybe your appetite isn’t what it
              was the first time. Lunch and dinner, five days a week — full
              recovery meals, with two cheat days each week to eat with family
              or on your own terms.
            </p>
            <div class="plan-spec">
              <div><strong>2 meals a day + dessert, 5 days/week</strong></div>
              <div>Herbal drinks add-on, {usd(products.frozen_herbal_drink_7_1w.price)}/week</div>
            </div>
            <div class="plan-price">{usd(products.frozen_essential_4w.price)}</div>
            <div class="plan-tag">
              4 weeks · FedEx Priority Overnight shipping included
            </div>
            <a href={planOrderUrls.frozenEssential} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card">
            <div class="plan-name">Frozen Soup &amp; Dessert</div>
            <div class="plan-chinese">冷凍幸福湯品</div>
            <p class="plan-persona">
              Some parts of recovery cooking take a whole day to do right. We’ve
              already done them. The daily postpartum soups, the nourishing
              recovery stews that rebuild blood and qi, an entrée, and the
              desserts — cooked, frozen, and ready to heat.
            </p>
            <div class="plan-spec">
              <div>
                <strong
                  >1 daily postpartum soup + 2 recovery stew soups + 1 entrée +
                  2 desserts</strong
                >
              </div>
              <div>Herbal drinks add-on, {usd(products.frozen_herbal_drink_7_1w.price)}/week</div>
            </div>
            <div class="plan-price">{usd(products.frozen_soup_dessert_4w.price)}</div>
            <div class="plan-tag">
              4 weeks · FedEx Priority Overnight shipping included
            </div>
            <a href={planOrderUrls.frozenSoupDessert} class="plan-link">Learn more →</a>
          </div>

          <div class="plan-card helper-card span2">
            <h4>How shipping works</h4>
            <p>
              Frozen meals ship via FedEx Priority Overnight — the fastest
              option available, so your food arrives at peak freshness. Each
              day’s meals come pre-portioned into a single bag — grab one bag,
              that’s your whole day. No guessing, no decisions.
            </p>
            <p style="margin-top:12px">
              <strong>If your freezer is small:</strong> Either pick up a small upright
              freezer (worth it if you’re doing a full month), or keep 5 days in the
              freezer and 2 days in the fridge — they thaw naturally as you go.
            </p>
            <a href={route("/sample")} class="helper-link"
              >→ Try the {usd(products.frozen_classic_sample_8item.price)} Frozen Tasting (8 items, real recipes)</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="band band-cream">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Side-by-side</p>
        <h2 id="compare-heading">All five plans, one quick look.</h2>
      </div>

      <div class="tab-content active" id="tab-compare-fresh">
        <div class="compare-wrap">
          <table class="compare">
            <thead>
              <tr
                ><th></th><th>Herbal</th><th>Classic</th><th>Vita</th><th
                  >Low Carb</th
                ><th>Easy</th></tr
              >
            </thead>
            <tbody>
              <tr
                ><td>Meals per day</td><td>3</td><td>3</td><td>2 + dessert</td
                ><td>3</td><td>Every other day</td></tr
              >
              <tr
                ><td>Daily herbal drinks</td><td class="included">Included</td
                ><td>Add-on {usd(products.herbal_drink.price)}/day</td><td>Add-on {usd(products.herbal_drink.price)}/day</td><td
                  >Add-on {usd(products.herbal_drink.price)}/day</td
                ><td>Add-on {usd(products.herbal_drink.price)}/day</td></tr
              >
              <tr
                ><td>What’s distinctive</td><td>Full traditional regimen</td><td
                  >Three meals, no herbal</td
                ><td>Lighter, no breakfast</td><td>Reduced carbs and sweets</td
                ><td>Every other day delivery</td></tr
              >
              <tr
                ><td>30-day price</td><td class="price">{usd(products.local_herbal_30d.price)}</td><td
                  class="price">{usd(products.local_classic_30d.price)}</td
                ><td class="price">{usd(products.local_vita_30d.price)}</td><td class="price">{usd(products.local_lowcarb_30d.price)}</td><td
                  class="price">{usd(products.local_easy_15d.price)}</td
                ></tr
              >
              <tr
                ><td>Best for</td><td class="best-for"
                  >The mom doing the full Zuo Yue Zi properly</td
                ><td class="best-for">The mom whose family handles the herbs</td
                ><td class="best-for"
                  >The mom with a smaller appetite or family cooking breakfast</td
                ><td class="best-for"
                  >The mom managing blood sugar or staying low-carb</td
                ><td class="best-for"
                  >The mom new to Chinese postpartum food, or who wants to ease
                  in without a daily commitment</td
                ></tr
              >
            </tbody>
          </table>
        </div>
        <p class="table-note">
          All Fresh plans available in 1, 7, 14, 21, or 30 days. 30 days is the
          traditional Zuo Yue Zi recommendation.
        </p>
      </div>

      <div class="tab-content" id="tab-compare-frozen">
        <div class="compare-wrap">
          <table class="compare">
            <thead>
              <tr
                ><th></th><th>Frozen Herbal</th><th>Frozen Classic</th><th
                  >Frozen Essential</th
                ><th>Frozen Soup &amp; Dessert</th></tr
              >
            </thead>
            <tbody>
              <tr
                ><td>What’s included</td><td
                  >3 meals + dessert + herbal drink</td
                ><td>3 meals + dessert</td><td>2 meals + dessert</td><td
                  >1 soup + 2 stew soups + entrée + 2 desserts</td
                ></tr
              >
              <tr
                ><td>Daily structure</td><td>3 meals daily</td><td
                  >3 meals daily</td
                ><td>2 meals, 5 days/week</td><td>Soups + entrée daily</td></tr
              >
              <tr
                ><td>Herbal drinks</td><td class="included">Included</td><td
                  >Add-on {usd(products.frozen_herbal_drink_7_1w.price)}/wk</td
                ><td>Add-on {usd(products.frozen_herbal_drink_7_1w.price)}/wk</td><td>Add-on {usd(products.frozen_herbal_drink_7_1w.price)}/wk</td></tr
              >
              <tr
                ><td>4-week price</td><td class="price">{usd(products.frozen_herbal_4w.price)}</td><td
                  class="price">{usd(products.frozen_classic_4w.price)}</td
                ><td class="price">{usd(products.frozen_essential_4w.price)}</td><td class="price">{usd(products.frozen_soup_dessert_4w.price)}</td></tr
              >
              <tr
                ><td>Best for</td><td class="best-for"
                  >The mom doing the full traditional program</td
                ><td class="best-for"
                  >The mom who wants three meals daily, hands off</td
                ><td class="best-for"
                  >The mom with a smaller appetite or her own breakfast routine</td
                ><td class="best-for"
                  >The mom who wants the hard-to-cook parts handled</td
                ></tr
              >
            </tbody>
          </table>
        </div>
        <p class="table-note">
          All Frozen plans available in 1, 2, 3, or 4 weeks. FedEx Priority
          Overnight shipping included in every price.
        </p>
      </div>
    </div>
  </section>

  <!-- HERBAL PROGRAM -->
  <section class="band band-paper">
    <div class="wrap">
      <div class="section-head reveal" style="max-width:820px">
        <p class="eyebrow">The Herbal Program</p>
        <h2>
          The part that turns Zuo Yue Zi from good recovery into deep recovery.
        </h2>
      </div>
      <div class="narrow" style="padding:0">
        <p class="lede-serif">
          If you’ve already chosen a meal plan, you might be wondering whether
          you really need the herbal drinks too. It’s a fair question. The meals
          do most of the heavy lifting — warmth, blood, milk, energy.
        </p>
        <p>
          But traditional Zuo Yue Zi was never just food. It was always food,
          herbs, and rest, working together. The drinks are the part that
          reaches the deeper layer — the joints, the circulation, the parts of
          recovery that matter long after the first month is over.
        </p>
        <p>
          That’s why most experienced postpartum families add them. Not because
          the meals aren’t enough. Because together is what the tradition was
          always meant to be.
        </p>
        <blockquote>
          I learned this on my own body. With my first baby, I did the meals but
          skipped the herbs. With my second, I did both. By week 3, the
          difference was unmistakable — my energy came back, my milk steadied,
          my joints stopped aching. That’s the reason this part of the program
          exists.
          <span class="attr">— Nicole Huang, JingMommy</span>
        </blockquote>

        <h3 class="herbal-h3">
          How the drinks match your three stages of recovery
        </h3>
        <p>
          The drinks follow the same three-stage framework as the meals — Mild,
          Warm, and Heat — because the body does different work each week, and
          the herbs match it.
        </p>
        <p>
          <strong>Week 1 — Mild: Cleanse and rest.</strong> Your body is still clearing
          lochia and resetting. The first formulas help that work happen gently, supporting
          circulation and internal cleansing without pushing the body before it’s
          ready.
        </p>
        <p>
          <strong>Week 2 — Warm: Replenish and rebuild.</strong> The body shifts from
          clearing to building. The Week 2 formulas support blood replenishment, joint
          and ligament recovery (your body is still reabsorbing the relaxin that loosened
          your joints during pregnancy), and milk supply.
        </p>
        <p>
          <strong>Weeks 3–4 — Heat: Strengthen and fortify.</strong> The deepest restoration
          phase. The strongest tonifying formulas come last, when the body is ready
          to receive them. This is the layer that supports energy, mood, sleep, and
          the long-term warmth Chinese medicine calls protection against 月內風 (yuè
          nèi fēng) — the cold-sensitivity and joint pain that can follow a woman
          for years if this window is missed.
        </p>

        <h3 class="herbal-h3">What’s in the drinks</h3>
        <p>
          Across 30 days, you receive <strong
            >15 different formulas — a new one every two days</strong
          > — each matched to the stage of recovery your body is in.
        </p>
        <p>
          The core ingredients are the herbs Chinese medicine has used for
          postpartum recovery for centuries:
        </p>
        <ul class="outcomes">
          <li>
            <strong>Dang Gui (當歸)</strong> — traditionally used to nourish and move
            blood
          </li>
          <li>
            <strong>Chuan Xiong (川芎)</strong> — used to support circulation and
            recovery from labor
          </li>
          <li>
            <strong>Bai Shao (白芍)</strong> — used to calm and balance, often paired
            with Dang Gui
          </li>
          <li>
            <strong>Shu Di (熟地)</strong> — used for deep blood replenishment
          </li>
          <li>
            <strong>Huang Qi (黃耆)</strong> — used to support energy and immune function
          </li>
          <li>And the supporting herbs that round out each stage’s formula</li>
        </ul>
        <p>
          This is not a single bundle brewed daily. Each of the 15 formulas is a
          specific combination, developed for that stage of recovery.
        </p>

        <h3 class="herbal-h3">What mothers tell us</h3>
        <p>
          Within the 30-day window, here’s what mothers on the herbal drinks
          come back to tell us most often:
        </p>
        <ul class="outcomes">
          <li>
            They feel like themselves again sooner — the fog lifts, the energy
            returns, and it happens earlier than they expected
          </li>
          <li>
            Their milk supply holds steady, even through the exhausting weeks
          </li>
          <li>
            They sleep better and feel more even, with less of the emotional
            crash
          </li>
          <li>The aches, the chill, and the night sweats settle down</li>
          <li>
            And the one mothers value most only shows up later: none of the
            lingering cold-sensitivity and joint pain (月內風) that Chinese
            medicine warns follows an incomplete recovery
          </li>
        </ul>
        <p style="font-style:italic;color:var(--muted)">
          Time and again, these are the patterns we hear from mothers who do the
          full program — not guarantees, but consistent enough that we mention
          them with confidence.
        </p>

        <div class="herbal-pricing">
          <h4>How to Get the Herbal Drinks</h4>
          <ul>
            <li>
              <strong>Included free</strong> in every Herbal Meal plan — fresh and
              frozen. The full 30-day course of drinks, no add-on cost.
            </li>
            <li>
              <strong>Add to a fresh meal plan — {usd(products.herbal_drink.price)}/day.</strong> Available with
              Classic, Vita, Low Carb, or Easy plans.
            </li>
            <li>
              <strong>Add to a frozen meal plan — {usd(products.frozen_herbal_drink_7_1w.price)}/week.</strong> Available with
              Classic, Essential, or Soup &amp; Dessert plans.
            </li>
            <li>
              <strong>{usd(products.herbal_drink_pack_30d.price)} standalone Herbal Pack.</strong> For the mom who has home-cooked
              meals covered, but doesn’t want to miss the herbal layer of Zuo Yue
              Zi. Ships nationwide.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SAMPLE CTA -->
  <section class="band band-paper">
    <div class="wrap">
      <div class="sample-cta reveal">
        <p class="eyebrow">Try Before You Commit</p>
        <h2>Most mothers want to taste the food before they choose a plan.</h2>
        <p>We made it easy to try.</p>
        <div class="sample-options">
          <div class="sample-option">
            <div class="place">Southern California</div>
            <div class="price-label">{usd(products.local_classic_sample_1d.price)} · Local Tasting</div>
            <p>
              A full sample day — breakfast, lunch, dinner, herbal drink,
              dessert. Delivered to your door.
            </p>
          </div>
          <div class="sample-option">
            <div class="place">Continental US</div>
            <div class="price-label">{usd(products.frozen_classic_sample_8item.price)} · Frozen Tasting</div>
            <p>
              8 individual items — sea bass soup, recovery stew soup, oil rice,
              main, dessert, breakfast porridge, herbal drink. Same recipes,
              same packaging as the full plan. Not a complete day’s meals — a
              real taste of what’s inside.
            </p>
          </div>
        </div>
        <a href={orderSampleUrl} class="btn btn-primary"
          >Order a Tasting</a
        >
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="band band-cream">
    <div class="narrow">
      <div class="section-head reveal" style="margin-bottom:40px">
        <p class="eyebrow">Frequently Asked</p>
        <h2>Questions other mothers have asked.</h2>
        <p style="font-style:italic;color:var(--muted);margin-top:16px">
          These are real questions our team answers every day. If yours isn’t
          here, call us at {brand.phone}.
        </p>
      </div>

      <details class="faq" open>
        <summary>Can I skip organ meats like liver and kidneys?</summary>
        <div class="answer">
          Organ meats carry specific nutritional value during recovery — that’s
          why they’ve been part of Zuo Yue Zi for centuries. If you’re hesitant,
          the broth itself still delivers much of the same benefit, so we’d
          encourage you to try the broth even if you skip the meat. If you can’t
          eat them at all, we can substitute — but the more we substitute, the
          less variety your menu will have over thirty days. Just tell us when
          you order.
        </div>
      </details>
      <details class="faq">
        <summary>I’m not Chinese. Is Zuo Yue Zi for me?</summary>
        <div class="answer">
          The principles behind Zuo Yue Zi — warmth, rest, targeted nourishment
          in stages — aren’t culturally exclusive. They’re biological. Your body
          recovers from birth the same way regardless of which tradition you
          grew up with. What’s different is that one tradition has been refining
          the answer for over 2,000 years.
        </div>
      </details>
      <details class="faq">
        <summary>What if the food tastes too unfamiliar?</summary>
        <div class="answer">
          This is exactly why we offer a tasting first. Most mothers expecting
          strange flavors are surprised by how warming and comforting the food
          actually is. Order the {usd(products.local_classic_sample_1d.price)} Local Tasting if you’re in our Southern
          California delivery area, or the {usd(products.frozen_classic_sample_8item.price)} Frozen Tasting if you’re not. If
          the food’s not for you, you’ll know before committing to a plan.
        </div>
      </details>
      <details class="faq">
        <summary>Can my partner and family eat the meals too?</summary>
        <div class="answer">
          Our meals are designed for one — the new mother. Many of our customers
          tell us the portions are large enough that their partner ends up
          sharing, but we can’t promise it. If you want enough food for both of
          you, the safer answer is to add a Daddy Meal or order a second
          portion. We’d rather be honest than have you run out three days in.
        </div>
      </details>
      <details class="faq">
        <summary
          >I had a C-section or a difficult birth — does that change anything?</summary
        >
        <div class="answer">
          All our plans use the same recovery food — including the warming,
          iron-replenishing dishes that line up well with C-section healing. The
          difference is the daily herbal drinks, which work alongside the food
          at a deeper level over the full thirty days. Many C-section moms
          choose the Herbal Meal for that reason. Choose the plan that fits when
          you order, and you can always adjust later.
        </div>
      </details>
      <details class="faq">
        <summary>What if I’m not breastfeeding?</summary>
        <div class="answer">
          We’ll remove the milk-stimulating ingredients from your menu. The food
          still does its main job — restoring blood, warmth, and energy after
          birth. The one thing to know: removing those ingredients means fewer
          dishes in rotation, so the menu can feel slightly more repetitive.
        </div>
      </details>
      <details class="faq">
        <summary
          >I’m outside your fresh delivery zone — how does shipping work?</summary
        >
        <div class="answer">
          Frozen meals ship via FedEx Priority Overnight, packed in thermal
          packaging with ice packs. Each day’s meals come pre-portioned into a
          single thermal bag — grab one bag, that’s your day. We ship to the
          continental US (not Alaska or Hawaii). If your freezer is small, you
          can pick up a small upright freezer or keep 5 days frozen and 2 days
          thawing in the fridge.
        </div>
      </details>
      <details class="faq">
        <summary>When should I order if my due date isn’t set yet?</summary>
        <div class="answer">
          Over 90% of orders come in before the due date — most mothers want one
          less thing to worry about. We recommend placing your order at least a
          month before your due date so we can hold a slot. Once the baby
          arrives, just let us know — your meals start whenever you notify us,
          not on a fixed calendar.
        </div>
      </details>
    </div>
  </section>

  <!-- FINAL CTA -->
