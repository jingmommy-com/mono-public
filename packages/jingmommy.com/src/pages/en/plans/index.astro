---
import Page from '@/layouts/themes/en/Page.astro'
import { products, site, phones } from '@/config/index.ts'
import { usd, phoneDisplay, route, formatNumber, getPathLocale } from '@/utils/index.ts'

const locale = getPathLocale(Astro.url.pathname)
const title =
  "Meal Plans — Chinese Postpartum (Zuo Yue Zi) Delivery — JingMommy"
---

<Page title={title}>
  <style is:global>


  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Georgia', 'Cambria', 'Times New Roman', serif;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.65;
    font-size: 17px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Sans-serif for UI elements */
  .sans { font-family: 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif; }

  /* Container */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 28px;
  }

  .narrow {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* Top nav (fake) */
  
  
  
  
  
  
  

  /* Section labels (small caps eyebrow) */
  .eyebrow {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  /* Typography */
  h1 {
    font-family: 'Georgia', serif;
    font-size: 56px;
    font-weight: normal;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 22px;
  }
  h2 {
    font-family: 'Georgia', serif;
    font-size: 38px;
    font-weight: normal;
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin-bottom: 24px;
  }
  h3 {
    font-family: 'Georgia', serif;
    font-size: 26px;
    font-weight: normal;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 12px;
  }
  p { margin-bottom: 16px; color: var(--ink-soft); }
  p.lede {
    font-style: italic;
    color: var(--muted);
    font-size: 19px;
    line-height: 1.6;
  }
  a { color: var(--accent-deep); text-decoration: underline; text-underline-offset: 3px; }
  a:hover { color: var(--ink); }

  /* Section spacing */
  section { padding: 88px 0; }
  section.dense { padding: 60px 0; }
  section.alt { background: var(--cream); }

  /* Divider rule */
  .rule {
    border: none;
    border-top: 1px solid var(--line);
    margin: 0;
  }

  /* Hero */
  .hero {
    padding: 80px 0 60px;
    text-align: center;
  }
  .hero h1 { max-width: 800px; margin-left: auto; margin-right: auto; }
  .hero .lede {
    max-width: 640px;
    margin: 0 auto 40px;
    font-size: 19px;
    font-style: normal;
    color: var(--ink-soft);
  }
  .hero-cta { margin-top: 8px; }
  .hero .hero-tabs {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--accent);
    color: white;
    text-decoration: none;
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: background 0.15s;
    border: none;
    cursor: pointer;
  }
  .btn:hover { background: var(--accent-deep); color: white; }
  .btn-outline {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
  }
  .btn-outline:hover { background: var(--ink); color: white; }

  /* Tab toggle */
  .tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--line);
    margin: 0 0 50px;
    background: white;
  }
  .tab {
    padding: 22px 28px;
    text-align: center;
    cursor: pointer;
    font-family: 'Helvetica Neue', sans-serif;
    border: none;
    background: white;
    color: var(--muted);
    transition: all 0.15s;
  }
  .tab.active {
    background: var(--accent);
    color: white;
  }
  .tab .tab-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .tab .tab-sub { font-size: 13px; opacity: 0.85; }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Plan grid */
  .plan-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .plan-card {
    background: white;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
  }
  .plan-name {
    font-family: 'Georgia', serif;
    font-size: 28px;
    font-weight: normal;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .plan-chinese {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 22px;
  }
  .plan-persona {
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.55;
    font-size: 17px;
    margin-bottom: 24px;
    flex-grow: 1;
  }
  .plan-spec {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink-soft);
    border-top: 1px solid var(--line-soft);
    padding-top: 18px;
    margin-bottom: 18px;
  }
  .plan-spec strong { color: var(--ink); font-weight: 600; }
  .plan-price {
    font-family: 'Georgia', serif;
    font-size: 32px;
    color: var(--accent-deep);
    margin-bottom: 4px;
  }
  .plan-tag {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .plan-also {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 12px;
    font-style: italic;
    color: var(--muted);
    margin-bottom: 18px;
  }
  .plan-link {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--accent-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-deep);
    align-self: flex-start;
    padding-bottom: 2px;
  }
  .plan-link:hover { color: var(--ink); border-color: var(--ink); }

  /* Helper card (inside grid) */
  .helper-card {
    background: var(--cream);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .helper-card h4 {
    font-family: 'Georgia', serif;
    font-size: 22px;
    font-weight: normal;
    margin-bottom: 14px;
  }
  .helper-card p { font-size: 16px; line-height: 1.6; }
  .helper-card .helper-link {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-deep);
    text-decoration: none;
    margin-top: 8px;
    display: block;
  }

  /* Comparison table */
  .compare-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    margin-top: 30px;
  }
  table.compare {
    width: 100%;
    border-collapse: collapse;
    background: white;
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 14px;
  }
  table.compare th, table.compare td {
    padding: 18px 16px;
    text-align: left;
    border-bottom: 1px solid var(--line-soft);
    vertical-align: top;
  }
  table.compare th {
    background: var(--cream);
    font-weight: 700;
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-align: center;
  }
  table.compare th:first-child { text-align: left; background: white; }
  table.compare td:first-child {
    font-weight: 600;
    color: var(--ink);
    width: 22%;
  }
  table.compare td:not(:first-child) {
    text-align: center;
    color: var(--ink-soft);
  }
  table.compare tr:last-child td { border-bottom: none; }
  table.compare .price { color: var(--accent-deep); font-weight: 700; font-size: 16px; }
  table.compare .included { color: var(--accent-deep); font-weight: 600; }
  table.compare .best-for { font-style: italic; line-height: 1.4; font-size: 13px; }

  .table-note {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    color: var(--muted);
    font-style: italic;
    margin-top: 16px;
    text-align: center;
  }

  /* Herbal program section (5) */
  .herbal-callout {
    background: white;
    border: 1px solid var(--line);
    padding: 40px;
    margin-top: 30px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .herbal-pricing {
    background: var(--cream);
    padding: 28px;
  }
  .herbal-pricing h4 {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .herbal-pricing ul { list-style: none; }
  .herbal-pricing li {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 14px;
    line-height: 1.8;
    padding: 10px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .herbal-pricing li:last-child { border-bottom: none; }
  .herbal-pricing strong { color: var(--accent-deep); }

  ul.outcomes {
    margin: 16px 0 24px 0;
    list-style: none;
  }
  ul.outcomes li {
    padding: 8px 0 8px 20px;
    position: relative;
    color: var(--ink-soft);
  }
  ul.outcomes li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--accent);
    font-weight: bold;
    font-size: 24px;
    line-height: 1;
    top: 8px;
  }

  blockquote {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 24px;
    line-height: 1.4;
    color: var(--ink);
    border-left: 4px solid var(--accent);
    padding: 12px 0 12px 28px;
    margin: 32px 0;
  }
  blockquote .attr {
    display: block;
    font-style: normal;
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-top: 14px;
  }

  /* Sample CTA */
  .sample-cta {
    background: var(--cream);
    padding: 64px 48px;
    text-align: center;
    border: 1px solid var(--line);
  }
  .sample-cta h2 { margin-bottom: 16px; }
  .sample-cta p { max-width: 560px; margin: 0 auto 32px; font-size: 18px; }
  .sample-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    margin: 32px auto;
    max-width: 720px;
    border: 1px solid var(--line);
  }
  .sample-option {
    background: white;
    padding: 28px 24px;
    text-align: left;
  }
  .sample-option .price-label {
    font-family: 'Georgia', serif;
    font-size: 22px;
    color: var(--accent-deep);
    margin-bottom: 6px;
  }
  .sample-option .place {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .sample-option p {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.55;
  }

  /* FAQ */
  details.faq {
    border-bottom: 1px solid var(--line-soft);
    padding: 24px 0;
  }
  details.faq:first-of-type { border-top: 1px solid var(--line-soft); }
  details.faq summary {
    font-family: 'Georgia', serif;
    font-size: 22px;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 40px;
    line-height: 1.4;
  }
  details.faq summary::-webkit-details-marker { display: none; }
  details.faq summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: 28px;
    color: var(--accent);
    font-weight: 300;
    transition: transform 0.2s;
  }
  details.faq[open] summary::after { content: '−'; }
  details.faq .answer {
    margin-top: 18px;
    color: var(--ink-soft);
    font-size: 17px;
    line-height: 1.7;
  }

  /* Final CTA */
  .final-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 36px;
  }
  .final-card {
    background: white;
    border: 1px solid var(--line);
    padding: 36px 28px;
    text-align: center;
  }
  .final-card h4 {
    font-family: 'Georgia', serif;
    font-size: 24px;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .final-card .sub {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 20px;
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--line);
    padding: 36px 0;
    text-align: center;
    color: var(--muted);
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.06em;
  }

  /* Designer note (visible to client during review only) */
  .designer-note {
    background: #FFFBF0;
    border-left: 3px solid #D4A847;
    padding: 12px 16px;
    margin: 20px 0;
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    color: #6B5410;
    font-style: italic;
  }
  .designer-note strong { color: #8B6F1A; font-style: normal; }

  /* Responsive */
  @media (max-width: 768px) {
    .plan-grid { grid-template-columns: 1fr; }
    .plan-grid .helper-card { grid-column: span 1 !important; }
  }
  @media (max-width: 720px) {
    h1 { font-size: 38px; }
    h2 { font-size: 28px; }
    .plan-grid { grid-template-columns: 1fr; }
    .herbal-callout { grid-template-columns: 1fr; }
    .final-actions { grid-template-columns: 1fr; }
    .sample-options { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
  </style>

<!-- Top nav -->

<!-- ========== SECTION 1: HERO (merged with Fresh/Frozen toggle) ========== -->
<section class="hero">
  <div class="container">
    <h1>Find the plan that fits your recovery.</h1>
    <p class="lede">Same kitchen, same recipes, same three-stage program — delivered fresh, or shipped frozen.</p>

    <!-- Tab toggle moved into hero -->
    <div class="tabs hero-tabs">
      <button class="tab active" data-tab="fresh">
        <div class="tab-title">Fresh Daily</div>
        <div class="tab-sub">Same-day delivery in Southern California</div>
      </button>
      <button class="tab" data-tab="frozen">
        <div class="tab-title">Frozen Nationwide</div>
        <div class="tab-sub">FedEx Priority Overnight to the continental US</div>
      </button>
    </div>
  </div>
</section>

<!-- ========== SECTION 2: THE PLANS ========== -->
<section class="dense" id="plans" style="padding-top: 0;">
  <div class="container">

    <!-- FRESH TAB CONTENT -->
    <div class="tab-content active" id="tab-fresh">
      <div class="narrow" style="text-align: center; padding: 0 0 30px; margin: 0 auto;">
        <p style="font-size: 14px; color: var(--muted);">Fresh delivery covers most areas of Southern California. <a href={route("/contact", locale) + "#delivery"}>Check your zip code →</a></p>
      </div>

      <div class="plan-grid">
        <!-- Herbal -->
        <div class="plan-card">
          <div class="plan-name">Herbal Meal</div>
          <div class="plan-chinese sans">藥膳月子餐</div>
          <p class="plan-persona">If you're going to do this, do it the full way. The complete program — every meal and the daily herbal drinks that have anchored Chinese postpartum recovery for two thousand years.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals a day</strong></div>
            <div>Daily herbal drinks <strong>included</strong></div>
          </div>
          <div class="plan-price">{usd(products.local_herbal_30d.price)}</div>
          <div class="plan-tag sans">30 days</div>
          <a href={route('/postpartum-meals/herbal-postpartum-meals', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Classic -->
        <div class="plan-card">
          <div class="plan-name">Classic Meal</div>
          <div class="plan-chinese sans">精緻月子餐</div>
          <p class="plan-persona">Three warm meals a day, ready when you are. Recovery food cooked the way it should be cooked, delivered to your door — so the only decision you make at lunchtime is when to eat.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals a day</strong></div>
            <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
          </div>
          <div class="plan-price">{usd(products.local_classic_30d.price)}</div>
          <div class="plan-tag sans">30 days</div>
          <a href={route('/postpartum-meals/classic-postpartum-meals', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Vita -->
        <div class="plan-card">
          <div class="plan-name">Vita Meal</div>
          <div class="plan-chinese sans">元氣月子餐</div>
          <p class="plan-persona">You don't need to be eating from the moment you wake up. Lunch, dinner, and a dessert — full recovery meals in a lighter daily rhythm, for the days when breakfast is already handled or you just don't want one.</p>
          <div class="plan-spec sans">
            <div><strong>2 meals a day + dessert</strong></div>
            <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
          </div>
          <div class="plan-price">{usd(products.local_vita_30d.price)}</div>
          <div class="plan-tag sans">30 days</div>
          <a href={route('/postpartum-meals/vita-postpartum-meals', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Low Carb -->
        <div class="plan-card">
          <div class="plan-name">Low Carb Meal</div>
          <div class="plan-chinese sans">減醣月子餐</div>
          <p class="plan-persona">You can recover and stay on plan. Three meals a day with the rice, porridge, and sweets set aside — for moms managing blood sugar, weight, or staying low-carb / keto-aware through postpartum.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals a day</strong></div>
            <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
          </div>
          <div class="plan-price">{usd(products.local_lowcarb_30d.price)}</div>
          <div class="plan-tag sans">30 days</div>
          <a href={route('/postpartum-meals/low-carb-postpartum-meals', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Easy -->
        <div class="plan-card">
          <div class="plan-name">Easy Meal</div>
          <div class="plan-chinese sans">輕享月子餐</div>
          <p class="plan-persona">New to Chinese postpartum food and not sure if you want to commit to thirty straight days? Start here. Real recovery meals delivered every other day — enough to feel the difference, light enough to ease into.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals a day, delivered 15 times</strong></div>
            <div>Herbal drinks add-on, {usd(products.herbal_drink.price)}/day</div>
          </div>
          <div class="plan-price">{usd(products.local_easy_15d.price)}</div>
          <div class="plan-tag sans">30 days</div>
          <a href={route('/postpartum-meals/easy-postpartum-meals', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Helper card -->
        <div class="helper-card">
          <h4>Not sure which one?</h4>
          <p>Most mothers start with Classic or Herbal. If you've never had Chinese postpartum food before, the easiest way to decide is to try a sample first.</p>
          <a href={route("/sample", locale)} class="helper-link sans">→ Try the {usd(products.local_classic_sample_1d.price)} Local Tasting</a>
          <a href={`tel:${phones.main}`} class="helper-link sans">→ Or call us at {phoneDisplay(phones.main)}</a>
        </div>
      </div>
    </div>

    <!-- FROZEN TAB CONTENT -->
    <div class="tab-content" id="tab-frozen">
      <div class="narrow" style="text-align: center; padding: 0 0 30px; margin: 0 auto;">
        <p class="lede">If you're outside our delivery area, you've probably been wondering whether real Zuo Yue Zi recovery is even possible from where you are. It is. Four plans, our same kitchen, frozen and shipped overnight to the continental US. Shipping included.</p>
        <p style="font-size: 14px; color: var(--muted); margin-top: 12px;">If you're in California, special pricing may apply — call us at <strong>{phoneDisplay(phones.main)}</strong>.</p>
      </div>

      <div class="plan-grid">
        <!-- Frozen Herbal -->
        <div class="plan-card">
          <div class="plan-name">Frozen Herbal Meal</div>
          <div class="plan-chinese sans">冷凍藥膳月子餐</div>
          <p class="plan-persona">You just did one of the hardest things a body can do. The next 30 days deserve a real plan, not whatever happens to be in the fridge. The complete program — every meal and the daily herbal drinks.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals + dessert + herbal drink</strong></div>
          </div>
          <div class="plan-price">{usd(products.frozen_herbal_4w.price)}</div>
          <div class="plan-tag sans">4 weeks · FedEx Priority Overnight shipping included</div>
          <a href={route('/frozen-postpartum-meals/herbal', locale)} class="plan-link sans">Learn more →</a>
        </div>

        <!-- Frozen Classic -->
        <div class="plan-card">
          <div class="plan-name">Frozen Classic Meal</div>
          <div class="plan-chinese sans">冷凍精緻月子餐</div>
          <p class="plan-persona">Three meals a day, every day, sent to your door — wherever your door is. The food does the work; you just heat and eat.</p>
          <div class="plan-spec sans">
            <div><strong>3 meals + dessert</strong> (no herbal drink)</div>
          </div>
          <div class="plan-price">{usd(products.frozen_classic_4w.price)}</div>
          <div class="plan-tag sans">4 weeks · FedEx Priority Overnight shipping included</div>
