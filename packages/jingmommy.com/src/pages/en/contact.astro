<!-- ============================================================
     SCRIPTS
     ============================================================ -->
<script is:inline define:vars={{ deliveryZipApi: orderUrl('delivery_zip_api', locale), salesPhone: phoneDisplay(phones.salesPatricia) }}>
/* ---- Reveal on scroll ---- */
(function(){
  var els = document.querySelectorAll('.reveal');
  if (!('IntersectionObserver' in window)){
    els.forEach(function(e){ e.classList.add('in'); });
    return;
  }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){
      if(en.isIntersecting){
        en.target.classList.add('in');
        io.unobserve(en.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  els.forEach(function(e){ io.observe(e); });

  /* close mobile nav on link click */
  document.querySelectorAll('#nav a').forEach(function(a){
    a.addEventListener('click', function(){
      document.getElementById('nav').classList.remove('open');
    });
  });
})();

/* ---- Contact form -> Web3Forms (AJAX, so we keep the inline success panel) ----
   access_key is a public client-side key, carried as a hidden field on the form. */
(function(){
  var form = document.getElementById('jm-form');
  if (!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var errEl = document.getElementById('form-error');
    if (errEl) errEl.classList.remove('visible');

    var name  = document.getElementById('f-name').value.trim();
    var email = document.getElementById('f-email').value.trim();
    if (!name)  { document.getElementById('f-name').focus();  return; }
    if (!email) { document.getElementById('f-email').focus(); return; }

    var btn = form.querySelector('button[type="submit"]');
    var btnLabel = btn ? btn.textContent : '';
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

    function fail(){
      if (btn) { btn.disabled = false; btn.textContent = btnLabel; }
      if (errEl) {
        errEl.textContent = 'Something went wrong sending your message. Please try again, or call or text us at ' + salesPhone + '.';
        errEl.classList.add('visible');
      }
    }

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body: JSON.stringify(Object.fromEntries(new FormData(form))),
    })
      .then(function(res){ return res.json(); })
      .then(function(json){
        if (!json || !json.success) throw new Error('submit failed');
        form.style.display = 'none';
        var success = document.getElementById('form-success');
        success.classList.add('visible');
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      })
      .catch(fail);
  });
})();

/* ---- ZIP delivery checker -> order-system API ----
   Maps delivery_code: 0 ask us · 1 local daily · 2 local every-other-day
   (surcharge) · 3 frozen/FedEx · 4 no service. */
var DELIVERY_MESSAGES = {
  '0': { cls: 'zip-result', text: 'We’re not certain about your area yet — contact us and we’ll check delivery for your ZIP.' },
  '1': { cls: 'zip-result fresh', text: 'Great news — we deliver fresh meals daily to most areas with your ZIP. Contact us to confirm your delivery day.' },
  '2': { cls: 'zip-result fresh', text: 'Good news — your ZIP qualifies for local every-other-day delivery. A delivery surcharge may apply; contact us to confirm the details for your area.' },
  '3': { cls: 'zip-result frozen', text: 'Your area is served by our frozen nationwide program — same meals, same ingredients, shipped via FedEx Priority Overnight in thermal packaging that holds temperature in transit.' },
  '4': { cls: 'zip-result', text: "We currently ship frozen meals to the continental US only, so we're not yet able to reach this ZIP code. Contact us and we'll let you know if that changes." },
};
function formatZip(str){
  return str.trim().replace(/[０-９]/g, function(ch){
    return String.fromCharCode(ch.charCodeAt(0) - 0xFF10 + 0x30);
  });
}
function checkZip(){
  var zip    = formatZip(document.getElementById('zip-input').value);
  var result = document.getElementById('zip-result');
  if (!/^\d{5}$/.test(zip)){
    result.textContent = 'Please enter a 5-digit ZIP code.';
    result.className   = 'zip-result';
    return;
  }
  result.textContent = 'Checking…';
  result.className   = 'zip-result';
  fetch(deliveryZipApi + '?zip_code=' + encodeURIComponent(zip))
    .then(function(res){ if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
    .then(function(data){
      var delivery_code = null;
      if (Array.isArray(data.data)){
        var row = data.data.find(function(r){ return r.zip_code === zip; });
        if (row && typeof row.delivery_code !== 'undefined') delivery_code = row.delivery_code;
      }
      var msg = DELIVERY_MESSAGES[String(delivery_code)] || DELIVERY_MESSAGES['0'];
      result.textContent = msg.text;
      result.className   = msg.cls;
    })
    .catch(function(){
      result.textContent = "We couldn't check that ZIP right now — please try again in a moment, or contact us and we'll look it up for you.";
      result.className   = 'zip-result';
    });
}

document.getElementById('zip-input').addEventListener('keydown', function(e){
  if (e.key === 'Enter') { e.preventDefault(); checkZip(); }
});

/* Bind buttons here (not via inline onclick) — the script is scoped, so its
   functions aren't reachable from an onclick attribute. */
document.getElementById('zip-check').addEventListener('click', checkZip);
document.getElementById('zip-scroll').addEventListener('click', function(){
  var input = document.getElementById('zip-input');
  input.scrollIntoView({ behavior: 'smooth', block: 'center' });
  input.focus();
});

/* ---- Mobile menu aria toggle ---- */
document.querySelector('.menu-btn').addEventListener('click', function(){
  var nav  = document.getElementById('nav');
  var open = nav.classList.contains('open');
  this.setAttribute('aria-expanded', String(!open));
});
</script>
</Page>
