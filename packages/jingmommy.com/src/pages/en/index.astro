---
import Page from '@/layouts/themes/en/Page.astro'
import Svg39 from '@/assets/en/svg/en-svg-39.svg'
import Svg40 from '@/assets/en/svg/en-svg-40.svg'
import Svg41 from '@/assets/en/svg/en-svg-41.svg'
import Svg42 from '@/assets/en/svg/en-svg-42.svg'
import Svg43 from '@/assets/en/svg/en-svg-43.svg'
import Svg44 from '@/assets/en/svg/en-svg-44.svg'
import Svg45 from '@/assets/en/svg/en-svg-45.svg'
import nicoleImg from '@/assets/en/nicole-huang.jpg'
import zyzImg from '@/assets/en/zyz-sesame-oil-chicken.jpg'
import { products, phones, site } from '@/config/index.ts'
import { usd, formatNumber, route, getPathLocale } from '@/utils/index.ts'

const locale = getPathLocale(Astro.url.pathname)
const title = "JingMommy — Authentic Chinese Postpartum Meals, Delivered"
const description =
  `JingMommy delivers authentic Chinese postpartum (Zuo Yue Zi) meals across the US. Founded ${site.founded}, ${formatNumber(site.mothersServed)}+ mothers served. Fresh daily in SoCal, frozen nationwide. Featured in LA Times, PBS & Washington Post. Sample meals from ${usd(products.local_classic_sample_1d.price)}.`

// "As featured in" outlets — only used on this page (single-page config).

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FoodEstablishment",
    name: "JingMommy",
    alternateName: "JingMommy Postpartum Meals",
    description:
      `Authentic Chinese postpartum (Zuo Yue Zi) meal delivery, founded ${site.founded}. Over ${formatNumber(site.mothersServed)} mothers served across the US. Fresh daily delivery in Southern California, frozen nationwide.`,
    url: "https://www.postpartummeal.com",
    telephone: `+1${phones.main}`,
    foundingDate: site.founded,
    address: site.address,
    areaServed: "United States",
    servesCuisine: "Chinese postpartum confinement meals (Zuo Yue Zi)",
    priceRange: "$-$$",
    founder: {
      "@type": "Person",
      name: "Nicole Huang",
      jobTitle: "Founder",
      description:
        "Founder of JingMommy and a leading English-language authority on Chinese postpartum care (Zuo Yue Zi).",
    },
    makesOffer: [
      {
        "@type": "Offer",
        name: "Herbal Meal Plan",
        price: String(products.local_herbal_30d.price),
        priceCurrency: "USD",
        description: "30-day plan: three meals plus a daily herbal drink.",
      },
      {
        "@type": "Offer",
        name: "Classic Meal Plan",
        price: String(products.local_classic_30d.price),
        priceCurrency: "USD",
        description: "30-day plan: three comforting meals a day.",
      },
      {
        "@type": "Offer",
        name: "Vita Meal Plan",
        price: String(products.local_vita_30d.price),
        priceCurrency: "USD",
        description: "30-day plan: two lighter meals plus a dessert.",
      },
      {
        "@type": "Offer",
        name: "Low Carb Meal Plan",
        price: String(products.local_lowcarb_30d.price),
        priceCurrency: "USD",
        description:
          "30-day plan: warming meals without rice, grains, or sweet drinks.",
      },
      {
        "@type": "Offer",
        name: "Easy Meal Plan",
        price: String(products.local_easy_15d.price),
        priceCurrency: "USD",
        description: "30-day plan: warm meals delivered every other day.",
      },
      {
        "@type": "Offer",
        name: "Sample Meal (local)",
        price: String(products.local_classic_sample_1d.price),
        priceCurrency: "USD",
        description:
          "A full day of sample meals, fresh delivery in Southern California.",
      },
      {
        "@type": "Offer",
        name: "Sample Meal (frozen nationwide)",
        price: String(products.frozen_classic_sample_8item.price),
        priceCurrency: "USD",
        description:
          "A full day of sample meals, frozen FedEx delivery nationwide.",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "What is Zuo Yue Zi?",
        acceptedAnswer: {
          "@type": "Answer",
          text: 'Zuo Yue Zi, literally "sitting the month," is the Chinese postpartum recovery tradition built around warmth, rest, and staged nourishment over about thirty days. It has been practiced for more than 2,000 years and is one of the most complete postpartum care systems in the world.',
        },
      },
    ],
  },
]
---

<Page title={title} description={description} jsonLd={jsonLd}>

  <style is:global>

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'EB Garamond','Georgia',serif;
  background:var(--paper);
  color:var(--ink);
  line-height:1.7;
  font-size:18px;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
.display{font-family:'Cormorant Garamond','Georgia',serif}
.sans{font-family:'Jost','Helvetica Neue',sans-serif}

/* ---- layout ---- */
.wrap{max-width:1120px;margin:0 auto;padding:0 32px}
.narrow{max-width:760px;margin:0 auto;padding:0 32px}

/* ---- eyebrow ---- */
.eyebrow{
  font-family:'Jost',sans-serif;
  font-size:12px;font-weight:400;
  letter-spacing:.32em;
  text-transform:uppercase;
  color:var(--accent-deep);
  margin-bottom:20px;
}

/* ---- headings ---- */
h1{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:74px;line-height:1.04;letter-spacing:.005em;color:var(--ink)}
.hero h1{letter-spacing:.15em;text-transform:uppercase;font-size:42px;line-height:1.22}
h2{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:48px;line-height:1.1;color:var(--ink)}
h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:30px;line-height:1.2;color:var(--ink)}
p{margin-bottom:18px}
p:last-child{margin-bottom:0}

/* ---- top bar ---- */










/* ---- botanical corners ---- */
.botan{position:absolute;pointer-events:none;opacity:.92;z-index:1}

/* ---- anchor offset for sticky nav ---- */
section[id]{scroll-margin-top:78px}

/* ---- hero ---- */
.hero{position:relative;overflow:hidden;padding:80px 0 104px;background:linear-gradient(180deg,var(--paper) 0%,var(--cream) 100%)}
.hero-inner{position:relative;z-index:3;max-width:880px;margin:0 auto;text-align:center;padding:0 32px}
.hero h1{margin-bottom:26px}
.hero .lede{font-size:22px;color:var(--ink-soft);max-width:780px;margin:0 auto 14px;white-space:nowrap}
.hero .trust{font-family:'Jost',sans-serif;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:38px}
.hero-cta{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.btn{font-family:'Jost',sans-serif;font-size:13px;letter-spacing:.14em;text-transform:uppercase;padding:16px 32px;border-radius:2px;cursor:pointer;text-decoration:none;display:inline-block;transition:all .25s;border:1px solid transparent}
.btn-primary{background:var(--accent-deep);color:var(--paper)}
.btn-primary:hover{background:var(--ink);transform:translateY(-1px)}
.btn-ghost{background:transparent;border-color:var(--accent-deep);color:var(--accent-deep)}
.btn-ghost:hover{background:var(--accent-deep);color:var(--paper)}

.hero-botan-tl{top:-20px;left:-30px;width:300px}
.hero-botan-br{bottom:-40px;right:-30px;width:330px}

/* ---- section base ---- */
section{position:relative}
.band{padding:104px 0}
.band-cream{background:var(--cream)}
.band-paper{background:var(--paper)}
.center{text-align:center}
.section-head{text-align:center;max-width:680px;margin:0 auto 64px}
.section-head .eyebrow{margin-bottom:18px}
.section-head p{font-size:19px;color:var(--muted);margin-top:18px}

/* ---- three steps ---- */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:48px;max-width:1000px;margin:0 auto}
.step{text-align:center;position:relative}
.step-num{font-family:'Cormorant Garamond',serif;font-size:22px;font-style:italic;color:var(--accent);margin-bottom:14px;letter-spacing:.05em}
.step h3{margin-bottom:12px}
.step p{font-size:16px;color:var(--muted)}
.step-rule{width:36px;height:1px;background:var(--accent);margin:0 auto 20px}

/* ---- pillars (what is zyz) ---- */
.zyz{display:grid;grid-template-columns:1.05fr .95fr;gap:72px;align-items:center;max-width:1060px;margin:0 auto}
.zyz-img{position:relative;border-radius:3px;overflow:hidden;min-height:440px;background:var(--cream-deep)}
.zyz-img img{width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0}
.zyz-body .eyebrow{margin-bottom:18px}
.zyz-body h2{margin-bottom:24px}
.zyz-body p{color:var(--ink-soft);font-size:18px}
.zyz-hook{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:24px;line-height:1.35;color:var(--ink);margin-bottom:22px}
.zyz-quote{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:23px;line-height:1.4;color:var(--accent-deep);border-left:2px solid var(--accent);padding-left:22px;margin:30px 0 0}

/* ---- partner note ---- */
.partner{max-width:720px;margin:64px auto 0;background:var(--paper);border:1px solid var(--line);border-radius:3px;padding:42px 46px;text-align:center;position:relative}
.partner .eyebrow{margin-bottom:14px}
.partner h3{font-size:27px;margin-bottom:18px}
.partner p{font-size:17px;color:var(--ink-soft);margin-bottom:14px}
.partner p:last-child{margin-bottom:0}

/* ---- three testimonials ---- */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1060px;margin:56px auto 0}
.testi-card{background:var(--paper);border:1px solid var(--line);border-radius:3px;padding:30px 26px;text-align:left;position:relative}
.testi-card .mark{display:none}
.testi-card .q{font-family:'EB Garamond',serif;font-size:16.5px;line-height:1.55;color:var(--ink-soft);margin:8px 0 18px;font-style:italic}
.testi-card .by{font-family:'Jost',sans-serif;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:3px}
.testi-card .ctx{font-size:13.5px;color:var(--muted)}

/* ---- stages ---- */
.stages{display:grid;grid-template-columns:repeat(3,1fr);gap:0;max-width:1040px;margin:60px auto 0;border-top:1px solid var(--line)}
.stage{padding:40px 30px;border-right:1px solid var(--line)}
.stage:last-child{border-right:none}
.stage-tag{font-family:'Jost',sans-serif;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:14px}
.stage h3{font-size:25px;margin-bottom:12px}
.stage p{font-size:15.5px;color:var(--muted)}

/* ---- differentiators ---- */
.diff{display:grid;grid-template-columns:repeat(3,1fr);gap:50px;max-width:1040px;margin:0 auto}
.diff-item{text-align:center}
.diff-mark{font-family:'Cormorant Garamond',serif;font-size:40px;color:var(--accent);line-height:1;margin-bottom:20px}
.diff-item h3{font-size:24px;margin-bottom:12px}
.diff-item p{font-size:16px;color:var(--muted)}

/* ---- plans ---- */
.plans{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;max-width:1080px;margin:0 auto}
.plan{background:var(--paper);border:1px solid var(--line);border-radius:3px;padding:30px 22px;text-align:center;display:flex;flex-direction:column;transition:all .25s}
.band-cream .plan{background:var(--paper)}
.plan:hover{border-color:var(--accent);transform:translateY(-3px)}
.plan.feat{border-color:var(--accent-deep);border-width:1.5px}
.plan-badge{font-family:'Jost',sans-serif;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-deep);height:16px;margin-bottom:8px}
.plan h3{font-size:23px;margin-bottom:6px}
.plan-price{font-family:'Cormorant Garamond',serif;font-size:30px;color:var(--ink);margin-bottom:4px}
.plan-per{font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}
.plan-desc{font-size:14.5px;color:var(--muted);line-height:1.55;flex:1;margin-bottom:10px}
.plan-persona{font-family:'Jost',sans-serif;font-size:11.5px;letter-spacing:.06em;color:var(--accent-deep);border-top:1px solid var(--line-soft);padding-top:12px;margin-bottom:0;font-style:italic}
/* botanical corner on plan cards */
.plan{position:relative;overflow:hidden}
.plan-botan{position:absolute;bottom:-8px;right:-8px;width:64px;height:64px;opacity:0.18;pointer-events:none}
.plan.feat .plan-botan{opacity:0.28}
/* botanical image slots — swap src for real vintage illustrations */
.botan-img{position:absolute;pointer-events:none;opacity:.9;z-index:1}
.botan-img.tl{top:-10px;left:-20px;width:260px}
.botan-img.br{bottom:-20px;right:-20px;width:290px}

/* ---- story ---- */
.story{display:grid;grid-template-columns:.85fr 1.15fr;gap:64px;align-items:center;max-width:1060px;margin:0 auto}
.story-portrait{position:relative;border-radius:3px;overflow:hidden;aspect-ratio:4/5;background:var(--cream-deep)}
.story-portrait img{width:100%;height:100%;object-fit:cover;display:block}
.story-body .eyebrow{margin-bottom:18px}
.story-body h2{margin-bottom:10px;font-size:42px}
.story-body .sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:25px;color:var(--accent-deep);margin-bottom:24px;line-height:1.3}
.story-body p{font-size:17px;color:var(--ink-soft)}
.story-sign{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:var(--ink);margin-top:24px}
.story-more{display:inline-block;margin-top:22px;font-family:'Jost',sans-serif;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent-deep);text-decoration:none;border-bottom:1px solid var(--accent);padding-bottom:3px;transition:all .2s}
.story-more:hover{color:var(--ink);border-color:var(--ink)}

/* ---- book teaser ---- */
.book-teaser{max-width:760px;margin:72px auto 0;text-align:center;border-top:1px solid var(--line);padding-top:48px}
.book-teaser .eyebrow{margin-bottom:14px}
.book-teaser h3{font-size:30px;margin-bottom:16px}
.book-teaser p{font-size:17px;color:var(--ink-soft);max-width:600px;margin:0 auto}

/* ---- testimonial ---- */
.testi{max-width:820px;margin:0 auto;text-align:center;position:relative;z-index:3}
.testi-quote{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:34px;line-height:1.32;color:var(--ink);margin-bottom:28px;letter-spacing:.12em;font-style:italic}
.testi-by{font-family:'Jost',sans-serif;font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-deep)}
.testi-context{font-size:16px;color:var(--muted);font-style:italic;margin-top:8px}
.testi-disclaimer{font-family:'Jost',sans-serif;font-size:11px;letter-spacing:.04em;color:var(--muted);opacity:.7;margin-top:18px}

/* ---- trust row ---- */
.trustband{padding:54px 0;background:var(--cream);border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft)}
.trust-row{display:flex;justify-content:center;align-items:center;gap:54px;flex-wrap:wrap;font-family:'Jost',sans-serif;font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.trust-row .featured{color:var(--ink);font-weight:400}
.trust-dot{width:4px;height:4px;border-radius:50%;background:var(--accent)}

/* ---- taste cta band ---- */
.taste{position:relative;overflow:hidden;padding:108px 0;background:var(--accent-deep);color:var(--paper);text-align:center}
.taste-inner{position:relative;z-index:3;max-width:680px;margin:0 auto;padding:0 32px}
.taste .eyebrow{color:#E8D5C2}
.taste h2{color:var(--paper);margin-bottom:22px}
.taste p{font-size:19px;color:#F0E4D8;margin-bottom:36px}
.taste .btn-primary{background:var(--paper);color:var(--accent-deep)}
.taste .btn-primary:hover{background:var(--cream);color:var(--ink)}
.taste .btn-ghost{border-color:#E8D5C2;color:#F0E4D8}
.taste .btn-ghost:hover{background:rgba(255,255,255,.12);color:#fff}

/* ---- footer ---- */











/* ---- reveal animation ---- */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .9s ease,transform .9s ease}
.reveal.in{opacity:1;transform:none}

/* ---- responsive ---- */
@media(max-width:900px){
  h1{font-size:52px}
  .hero h1{font-size:40px;letter-spacing:.14em}
  h2{font-size:38px}
  .nav{display:none}
  .nav.open{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;background:var(--paper);padding:24px 32px;gap:20px;border-bottom:1px solid var(--line);align-items:flex-start}
  .menu-btn{display:block}
  .zyz,.story{grid-template-columns:1fr;gap:40px}
  .story-portrait{aspect-ratio:3/4;max-width:380px;margin:0 auto}
  .steps,.diff{grid-template-columns:1fr;gap:44px}
  .stages{grid-template-columns:1fr}
  .stage{border-right:none;border-bottom:1px solid var(--line)}
  .stage:last-child{border-bottom:none}
  .plans{grid-template-columns:1fr 1fr;gap:12px}
  .footer-grid{grid-template-columns:1fr 1fr}
  .band{padding:72px 0}
  .hero{padding:64px 0 72px}
  .hero-botan-tl{width:180px}
  .hero-botan-br{width:200px}
  .testi-quote{font-size:26px}
  .testi-grid{grid-template-columns:1fr;gap:16px;margin-top:36px}
  .partner{padding:32px 26px;margin-top:48px}
}
@media(max-width:560px){
  h1{font-size:42px}
  .hero h1{font-size:30px;letter-spacing:.10em}
  .hero .lede{font-size:15px;white-space:normal}
  .eyebrow{font-size:10px;letter-spacing:.18em}
  .hero .eyebrow{white-space:nowrap;font-size:9.5px;letter-spacing:.15em}
  .plans{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .wrap,.narrow{padding:0 22px}
  .btn{padding:14px 18px;font-size:11px;letter-spacing:.10em}
}
@media(prefers-reduced-motion:reduce){
  .reveal{opacity:1;transform:none;transition:none}
  html{scroll-behavior:auto}
}
  </style>

<!-- ============ TOP BAR ============ -->

<!-- ============ HERO ============ -->
<section class="hero">
  <!-- botanical illustration corners (vintage rose, watercolor) -->
  <Svg39 class="botan hero-botan-tl" aria-hidden="true" />
  <Svg40 class="botan hero-botan-br" aria-hidden="true" />

  <div class="hero-inner">
    <p class="eyebrow reveal">Since {site.founded} · The real Zuo Yue Zi, in English</p>
    <h1 class="reveal">You planned everything, except the <span style="color:#A8842C;font-size:1.15em;font-weight:600">RECOVERY.</span></h1>
    <p class="lede reveal">Fresh, hot Chinese postpartum meals — delivered to your door, every single day.</p>
    <div class="hero-cta reveal">
      <a href="#plans" class="btn btn-primary">Explore meal plans</a>
      <a href="#taste" class="btn btn-ghost">Try a Taste — Free or from {usd(products.local_classic_sample_1d.price)}</a>
    </div>
  </div>
</section>

<!-- ============ THE PROBLEM ============ -->
<section class="band band-paper">
  <div class="narrow center reveal">
    <p class="eyebrow">The fourth trimester</p>
    <h2 style="margin-bottom:28px">The trimester nobody<br>prepares you for.</h2>
    <p style="font-size:19px;color:var(--ink-soft)">You've been told how to prepare for pregnancy. For birth. But almost no one tells you how to <em>recover</em> — how to rebuild a body that just spent nine months building a person.</p>
    <p style="font-size:19px;color:var(--ink-soft)">For over 2,000 years, Chinese mothers have known the answer. They call it Zuo Yue Zi — sitting the month — and it works. We make it simple to follow, wherever you are.</p>
  </div>
</section>

<!-- ============ THREE STEPS ============ -->
<section class="band band-cream">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">How it works</p>
      <h2>Three steps to a gentler recovery</h2>
    </div>
    <div class="steps">
      <div class="step reveal">
        <div class="step-rule"></div>
        <p class="step-num">Step one</p>
        <h3>Learn</h3>
        <p>New to Zuo Yue Zi? We explain the tradition, the three stages of recovery, and what to eat — in plain English, without the guilt.</p>
      </div>
      <div class="step reveal">
        <div class="step-rule"></div>
        <p class="step-num">Step two</p>
        <h3>Taste</h3>
        <p>Join a free local tasting, or order a sample meal for {usd(products.local_classic_sample_1d.price)} local or {usd(products.frozen_classic_sample_8item.price)} frozen nationwide. Try the food before you commit — most mothers do exactly that.</p>
      </div>
      <div class="step reveal">
        <div class="step-rule"></div>
        <p class="step-num">Step three</p>
        <h3>Recover</h3>
        <p>Choose your plan. We deliver fresh daily across Southern California, or frozen nationwide. You rest. We cook.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ WHAT IS ZUO YUE ZI ============ -->
<section class="band band-paper" id="zyz">
  <div class="wrap">
    <div class="zyz">
      <div class="zyz-img reveal">
        <img src={zyzImg.src} alt="A black bowl of sesame oil chicken soup with goji berries — a classic Zuo Yue Zi postpartum dish from JingMommy">
      </div>
      <div class="zyz-body reveal">
        <p class="eyebrow">Restorative wisdom</p>
        <h2>What is Zuo Yue Zi?</h2>
        <p class="zyz-hook">If you grew up hearing "you should do Zuo Yue Zi" but had no idea how to start — or your partner thinks it sounds old-fashioned — this is for you.</p>
        <p>Zuo Yue Zi (坐月子), literally "sitting the month," is the Chinese practice of structured postpartum recovery through warmth, rest, and staged nourishment. Practiced for over 2,000 years, it's not a fad, not a restrictive ritual, and not reserved for Chinese families.</p>
        <p>What you eat in the first 30 days after birth shapes your hormones, your milk supply, and your energy — for months to come.</p>
        <p class="zyz-quote">"In Chinese tradition, the first month after birth is not a burden to endure — it is the most important gift a woman can give herself."</p>
      </div>
    </div>

    <!-- three stages -->
    <div class="stages">
      <div class="stage reveal">
        <p class="stage-tag">Week 1 · Mild</p>
        <h3>Gentle start</h3>
