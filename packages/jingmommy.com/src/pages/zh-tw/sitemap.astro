---
import Layout from '@/layouts/Page.astro'
import routeMap from '@/route-map.json'

const sitemap = false
const locale = 'zh-tw'
const prefix = `/${locale}`

type RouteEntry = { title?: string; sitemap?: boolean }
const allRoutes = routeMap as Record<string, RouteEntry>
const excluded = new Set(['/404', '/', prefix])

const routes = Object.entries(allRoutes)
  .filter(([href, meta]) => href.startsWith(prefix + '/') && !excluded.has(href) && meta.sitemap !== false)
  .sort(([a], [b]) => a.localeCompare(b))

// Group by top-level section
const sectionMap = new Map<string, { sectionTitle: string; pages: { href: string; title: string }[] }>()
for (const [href, meta] of routes) {
  const topSegment = href.slice(prefix.length + 1).split('/')[0]
  const sectionHref = `${prefix}/${topSegment}`
  if (!sectionMap.has(sectionHref)) {
    sectionMap.set(sectionHref, {
      sectionTitle: allRoutes[sectionHref]?.title ?? topSegment,
      pages: [],
    })
  }
  sectionMap.get(sectionHref)!.pages.push({ href, title: meta.title ?? href })
}

const sections = [...sectionMap.entries()].map(([sectionHref, data]) => ({ sectionHref, ...data }))
---

<Layout title="網站地圖">
  <div class="flex flex-col gap-8 pb-8">
    {sections.map(({ sectionHref, sectionTitle, pages }) => (
      <div>
        <h2 class="text-xl font-bold text-orange-800 mb-2 border-b border-orange-200 pb-1">
          <a href={sectionHref} class="hover:underline">{sectionTitle}</a>
        </h2>
        <ul class="flex flex-col gap-1 pl-4">
          {pages.map(({ href, title }) => (
            <li>
              <a href={href} class="text-orange-700 hover:underline">{title}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Layout>
