const title = '餐點實品拍攝'
const color = 'rose'

const dishes = [
  { text: '花生薏仁湯', src: dessert_peanuts, alt: 'dessert peanuts' },
  { text: '紅豆湯', src: dessert_red_bean, alt: 'dessert red bean' },
  { text: '紅豆紫米粥', src: dessert_red_bean_sweet_rice, alt: 'dessert red bean sweet rice' },
  { text: '桂圓糯米粥', src: dessert_sweet_rice, alt: 'dessert sweet rice' },
  { text: '紅棗銀耳甜湯', src: dessert_tremella, alt: 'dessert tremella' },
  { text: '玉米烘蛋', src: egg_corn, alt: 'egg corn' },
  { text: '甜蜜雙棗茶', src: herbal_drink_01, alt: 'herbal drink 01' },
  { text: '滋補紅棗桂圓茶', src: herbal_drink_02, alt: 'herbal drink 02' },
  { text: '生化湯', src: herbal_drink_seng_hua_tang, alt: 'herbal drink seng hua tang' },
  { text: '香菇高麗菜雞粥', src: porridge_cabbage_mushroom, alt: 'porridge cabbage mushroom' },
  { text: '火腿雞蓉玉米粥', src: porridge_corn_ham, alt: 'porridge corn ham' },
  { text: '紅豆燕麥粥', src: porridge_red_bean_oatmeal, alt: 'porridge red bean oatmeal' },
  { text: '糙米飯', src: rice_brown, alt: 'rice brown' },
  { text: '鮭魚拌飯', src: rice_salmon, alt: 'rice salmon' },
  { text: '麻油蛋炒飯', src: rice_sesame_fried_rice, alt: 'rice sesame fried rice' },
  { text: '藥膳牛腱湯', src: soup_beef_herb, alt: 'soup beef herb' },
  { text: '山藥紅蘿蔔牛肉湯', src: soup_beef_mountain_yam, alt: 'soup beef mountain yam' },
  { text: '黃豆紅蘿蔔牛腱湯', src: soup_beef_soy_bean, alt: 'soup beef soy bean' },
  { text: '紅酒燉牛尾', src: soup_beef_tail_wine, alt: 'soup beef tail wine' },
  { text: '鮑魚山藥燉雞湯', src: soup_chicken_abalone, alt: 'soup chicken abalone' },
  { text: '紅棗木耳燉雞湯', src: soup_chicken_fugus_date, alt: 'soup chicken fugus date' },
  { text: '紅棗竹笙燉雞湯', src: soup_chicken_ginseng_date, alt: 'soup chicken ginseng date' },
  { text: '枸杞麻油雞', src: soup_chicken_sesame_date, alt: 'soup chicken sesame date' },
  { text: '藥膳麻油雞', src: soup_chicken_sesame_herbal, alt: 'soup chicken sesame herbal' },
  { text: '紅棗枸杞鱸魚湯', src: soup_fish_date, alt: 'soup fish date' },
  { text: '當歸黃芪鱸魚湯', src: soup_fish_herbal, alt: 'soup fish herbal' },
  { text: '紅莧菜枸杞鱸魚湯', src: soup_fish_veggie, alt: 'soup fish veggie' },
  { text: '杜仲麻油腰花', src: soup_kidney, alt: 'soup kidney' },
  { text: '四物排骨湯', src: soup_pork_4herbs, alt: 'soup pork 4herbs' },
  { text: '南北杏排骨湯', src: soup_pork_almond, alt: 'soup pork almond' },
  { text: '黑豆紅棗燉豬腳', src: soup_pork_feet_black_bean, alt: 'soup pork feet black bean' },
  { text: '黑棗花生豬腳湯', src: soup_pork_feet_peanuts, alt: 'soup pork feet peanuts' },
  { text: '木耳排骨湯', src: soup_pork_fungus, alt: 'soup pork fungus' },
  { text: '當歸黨參豬心湯', src: soup_pork_heart_herbal, alt: 'soup pork heart herbal' },
  { text: '八珍排骨湯', src: soup_pork_herb, alt: 'soup pork herb' },
  { text: '波菜豬肝湯', src: soup_pork_liver_spinach, alt: 'soup pork liver spinach' },
  { text: '青木瓜燉排骨湯', src: soup_pork_papaya, alt: 'soup pork papaya' },
  { text: '當歸枸杞川芎蝦', src: soup_shrimp_herb, alt: 'soup shrimp herb' }
]
---

<Layout title={title} color={color}>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
    {dishes.map(({ text, src, alt }) => (
      <div class="flex flex-col items-center gap-0.5">
        <Image src={src} alt={alt} class="cursor-zoom-in" />
        <span class="text-center">{text}</span>
      </div>
    ))}
  </div>
</Layout>
