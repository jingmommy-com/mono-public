---
import Layout from '@/layouts/FullScreenLoading.astro'
import { locales } from '@/client.config.ts'

const title = 'JingMommy'
const locale = locales.includes(Astro.preferredLocale ?? '') ? Astro.preferredLocale : locales[0]
const target = `/${locale}/`
const delay = import.meta.env.DEV ? 2000 : 0
---

<Layout title={title}>
  <script is:inline define:vars={{ target, delay }}>
    setTimeout(() => { window.location.href = target }, delay)
  </script>
</Layout>