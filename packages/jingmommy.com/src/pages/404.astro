---
/*
  Theme-aware 404.

  A static site serves a single /404.html for every not-found URL, so the theme
  can't be chosen at build time — it's chosen client-side from the path prefix:
    • /zh-tw/* and /en-translated/*  → base theme (also covers `modern`, which falls back to base)
    • everything else (/en/*, unknown roots) → en theme

  Both themed bodies are rendered; an inline head script sets `data-nf` on <html>
  before paint and CSS hides the non-matching one (no flash of the wrong theme).
*/
import '@/styles/global.css'
import BaseNotFound from '@/layouts/themes/base/NotFound.astro'
import EnNotFound from '@/layouts/themes/en/NotFound.astro'

const title = '404 — Page Not Found · JingMommy'
---

<!doctype html>
<html lang="en" data-nf="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      ;(function () {
        var p = location.pathname
        var isBase = p.indexOf('/zh-tw') === 0 || p.indexOf('/zh-cn') === 0 || p.indexOf('/en-translated') === 0
        document.documentElement.setAttribute('data-nf', isBase ? 'base' : 'en')
      })()
    </script>
  </head>
  <body>
    <div class="nf-slot nf-base"><BaseNotFound /></div>
    <div class="nf-slot nf-en"><EnNotFound /></div>
  </body>
</html>

<style>
  html[data-nf='en'] .nf-base {
    display: none;
  }
  html[data-nf='base'] .nf-en {
    display: none;
  }
</style>
