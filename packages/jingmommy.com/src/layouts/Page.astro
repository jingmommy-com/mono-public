---
/**
 * Theme router for Page layout.
 * Delegates to src/layouts/themes/<theme>/Page.astro.
 * Falls back to base theme if the requested theme is not registered here.
 *
 * To add a new theme: import its Page.astro and add it to `themeMap` below.
 */
import BasePage from './themes/base/Page.astro'
import ModernPage from './themes/modern/Page.astro'
import type { ThemeName } from '@/themes.ts'

const themeMap: Record<ThemeName, any> = {
  base:   BasePage,
  modern: ModernPage,
}

const { theme = 'base', ...rest } = Astro.props as { theme?: ThemeName; [key: string]: unknown }
const Layout = themeMap[theme] ?? BasePage
---
<Layout {...rest}><slot /></Layout>
