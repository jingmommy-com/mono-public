---
import Layout from './Page.astro'
import Markdown from '@/components/Markdown.astro'

const { frontmatter = {}, title: propTitle, color: propColor } = Astro.props
const title = frontmatter.title ?? propTitle ?? null
const color = frontmatter.color ?? propColor ?? null
---

<Layout title={title} color={color}>
  <Markdown theme='starwind' class='max-w-full'>
    <slot />
  </Markdown>
</Layout>
