---
import Layout from '../../SharedBase.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import Footer from '@/components/Footer.astro'
import SideNav from '@/components/SideNav.astro'
import { colors } from '@/client.config.ts'

const { title, color: inputColor } = Astro.props
const color = colors.includes((inputColor ?? '').trim()) ? (inputColor ?? '').trim() : 'orange'

const heroBg = `bg-${color}-500`
const crumbBg = `bg-${color}-50`
const borderColor = `border-${color}-200`
---

<Layout color={color} hasSidebar={true}>
  <SideNav currentPath={Astro.url.pathname} color={color} />

  <!-- Thin breadcrumb strip above the hero -->
  <div class={`w-full ${crumbBg} border-b ${borderColor} px-4 sm:px-6 py-2`}>
    <Breadcrumb color={color} />
  </div>

  <!-- Bold hero banner: large centered title on solid color -->
  <div class={`w-full ${heroBg} px-6 sm:px-10 py-12 sm:py-16 flex flex-col items-center justify-center text-center`}>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight tracking-wide drop-shadow">
      {title?.trim() ?? ''}
    </h1>
  </div>

  <!-- Content area -->
  <div class="flex flex-col w-full px-4 sm:px-8 py-8">
    <slot />
    <div class={`border-t ${borderColor} mt-8`}></div>
    <Footer color={color} />
  </div>
</Layout>
