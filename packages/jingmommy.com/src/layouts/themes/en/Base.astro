---
/*
  Minimal Base shell for the "en" (postpartummeal.com) design.

  Fidelity-first rebuild: every en page is fully STANDALONE — it inlines its own
  <style is:global>, its full markup (top bar, sections, footer), and its own
  <script>, transcribed 1:1 from docs/en/*.html. This shell intentionally owns
  nothing visual; it only provides:
    - the <html>/<head> via the shared Head.astro (SEO, favicons, base meta)
    - a `head` slot for the page's own font <link>s + JSON-LD
    - the <body> wrapper

  Anything worth sharing (top bar, footer, botanicals, plan cards…) is a
  post-rebuild refactor, deliberately deferred so the layout can be verified
  against the source HTML first.
*/
import '@/styles/themes/en/theme.css'
import Head from '@/components/Head.astro'
import LangSwitch from '@/components/themes/en/LangSwitch.astro'

interface Props {
  title: string
  description?: string
  /** JSON-LD structured-data objects to inline in <head>. */
  jsonLd?: unknown[]
}

const { title, description, jsonLd = [] } = Astro.props
const headProps = { title, ...(description ? { description } : {}) }
---

<!doctype html>
<html lang="en">
  <Head {...headProps}>
    <slot name="head" />
    {
      jsonLd.map((obj) => (
        <script type="application/ld+json" set:html={JSON.stringify(obj)} />
      ))
    }
    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
      }
    </style>
  </Head>
  <body>
    <slot />
    <LangSwitch />
  </body>
</html>
