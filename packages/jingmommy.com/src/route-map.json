  "/en/about/founding-story": {
    "title": "Our Story — Nicole Huang, Founder of JingMommy",
    "description": "Nicole Huang built JingMommy to bring authentic Chinese postpartum care — Zuo Yue Zi — to mothers across America. Over 10,000 families served since 2010. Featured in LA Times and PBS."
  },
  "/en/about/testimonial": {
    "title": "Real Stories — Mothers on JingMommy Postpartum Meals",
    "description": "Real reviews from mothers who tried authentic Chinese postpartum (Zuo Yue Zi) meals — Chinese, ABC, and non-Chinese moms across the US. First-name attribution, honest voice, results-vary disclosure."
  },
  "/en/contact": {
    "title": "Contact & Order — JingMommy Postpartum Meals",
    "description": "Contact JingMommy to order, gift, or plan Chinese postpartum (Zuo Yue Zi) meals. Call or text 626-217-7539, send a message, or check delivery to your ZIP. English & Chinese spoken."
  },
  "/en/faq": {
    "title": "Frequently Asked Questions — JingMommy Zuo Yue Zi Postpartum Meals",
    "description": "Answers to the questions families ask most about JingMommy’s Zuo Yue Zi postpartum meal plans — the tradition, the food, breastfeeding, delivery, plans, and ordering."
  },
  "/en/guide/chinese-food-therapy": {
    "title": "Chinese Food Therapy for Postpartum Recovery — JingMommy",
    "description": "Chinese food therapy (食療) for postpartum recovery: ginger, sesame oil, rice wine, red dates, goji, Dang Gui, sesame oil chicken and sea bass soup — the science and tradition behind every JingMommy meal."
  },
  "/en/guide/why-zuo-yue-zi": {
    "title": "What Is Zuo Yue Zi? The Chinese Postpartum Tradition — JingMommy",
    "description": "Zuo Yue Zi is the 2,000-year-old Chinese practice of structured postpartum recovery through warmth, rest, and staged nourishment. Learn the three-stage framework, four principles, and what to eat."
  },
  "/en": {
    "title": "JingMommy — Authentic Chinese Postpartum Meals, Delivered",
    "description": "JingMommy delivers authentic Chinese postpartum (Zuo Yue Zi) meals across the US. Founded 2010, 10,000+ mothers served. Fresh daily in SoCal, frozen nationwide. Featured in LA Times, PBS & Washington Post. Sample meals from $50."
  },
  "/en/plans": {
    "title": "Meal Plans — Chinese Postpartum (Zuo Yue Zi) Delivery — JingMommy",
    "description": "Five fresh and four frozen 30-day Chinese postpartum meal plans, from $1,550. Same kitchen, same three-stage Zuo Yue Zi program — delivered fresh in SoCal or shipped frozen nationwide."
  },
  "/en/sample": {
    "title": "Try a Taste — Free Tasting & Sample Meals — JingMommy",
    "description": "Taste authentic Chinese postpartum meals before you commit. Join a free tasting event in Southern California, or order a full sample day — $50 fresh local, $80 frozen nationwide. Gift options too."
  },
